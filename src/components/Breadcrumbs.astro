---
interface Crumb { label: string; href?: string }
interface Props { items: Crumb[] }
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Migas de pan"><a href="/">Inicio</a>{items.map((item) => <><span aria-hidden="true">/</span>{item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}</>)}</nav>
