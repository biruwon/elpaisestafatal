---
import { getRegionSeries } from '../data/regions';
import type { ConversationMvpClaim } from '../data/conversationMvp';
interface Props { claim: ConversationMvpClaim }
const { claim }: Props = Astro.props;
const regional = claim.visuals.regionTopic ? getRegionSeries(claim.visuals.regionTopic) : null;
const regionalValues = regional?.values.filter((item) => item.value !== null).sort((a,b) => (b.value ?? 0) - (a.value ?? 0)).slice(0, 5) ?? [];
const comparisonMax = Math.max(...claim.visuals.comparison.values);
---
<div class="key-number-row"><div class="key-number"><strong>{claim.visuals.key.value}</strong><span>{claim.visuals.key.label}</span><small>{claim.visuals.key.period}</small></div><div class="key-number key-number-text"><strong>3</strong><span>preguntas distintas dentro de la frase</span><small>Descomposición del claim</small></div><div class="key-number key-number-text"><strong>1</strong><span>límite que cambia la interpretación</span><small>Contexto necesario</small></div></div>
<div class="visual-grid">
  <div class="visual-card visual-wide"><div class="visual-heading"><div><span class="card-kicker">Tendencia</span><strong>{claim.visuals.trend.label}</strong></div><small>{claim.visuals.trend.unit}</small></div>{claim.visuals.trend.available ? <div class="trend-chart">{claim.visuals.trend.values.map((value, index) => <div class="trend-point" style={`--point:${value}%`}><i></i><span>{claim.visuals.trend.labels[index]}</span></div>)}</div> : <div class="unavailable-chart"><strong>Serie temporal no conectada todavía</strong><span>La respuesta no inventa una tendencia. Cuando exista una serie comparable, aparecerá aquí con su fuente, unidad y periodo.</span></div>}<p class="visual-note">La visual debe responder exactamente a la afirmación, no solo al tema general.</p></div>
  <div class="visual-card"><div class="visual-heading"><div><span class="card-kicker">Comparación</span><strong>{claim.visuals.comparison.label}</strong></div><small>{claim.visuals.comparison.unit}</small></div><div class="bar-list">{claim.visuals.comparison.labels.map((label, index) => <div><div><span>{label}</span><b>{claim.visuals.comparison.values[index]}</b></div><i style={`--bar:${Math.min(100, claim.visuals.comparison.values[index] / comparisonMax * 100)}%`}></i></div>)}</div></div>
  <div class="visual-card"><div class="visual-heading"><div><span class="card-kicker">Territorio</span><strong>{regional?.title ?? 'Comparación autonómica'}</strong></div><small>{regional?.unit ?? 'Datos no disponibles'}</small></div>{regional ? <><div class="region-list">{regionalValues.map((item) => <div><span>{item.region}</span><i><b style={`width:${Math.min(100, (item.value ?? 0) / Math.max(...regionalValues.map((value) => value.value ?? 0)) * 100)}%`}></b></i><em>{item.value}</em></div>)}</div><p class="visual-note">{regional.period} · {regional.source.label}</p></> : <div class="unavailable-chart"><strong>Serie autonómica no disponible</strong><span>No se sustituye por una cifra local incomparable.</span></div>}</div>
</div>
<div class="visual-caveat"><strong>Cómo leerlo</strong><span>{claim.visuals.caveat}</span></div>
<style>
  .key-number-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin-bottom:1px}.key-number{background:var(--paper);padding:24px;display:flex;flex-direction:column}.key-number strong{font:400 clamp(2.6rem,5vw,5rem)/.85 var(--serif);color:var(--red);letter-spacing:-.06em}.key-number span{font:1rem/1.15 var(--serif);margin-top:14px}.key-number small{font:600 .62rem var(--mono);text-transform:uppercase;margin-top:auto;padding-top:20px;color:var(--muted)}.visual-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line)}.visual-card{background:var(--paper);padding:24px;min-height:260px}.visual-wide{grid-column:span 2}.visual-heading{display:flex;justify-content:space-between;gap:20px}.visual-heading strong{display:block;font:1.35rem/1 var(--serif);margin-top:10px}.visual-heading small{font:600 .62rem var(--mono);text-transform:uppercase;color:var(--muted);text-align:right}.trend-chart{height:180px;display:flex;align-items:end;gap:8px;border-bottom:1px solid var(--ink);margin-top:28px;padding:0 8px}.trend-point{height:100%;flex:1;position:relative;display:flex;align-items:end}.trend-point i{height:var(--point);width:100%;background:linear-gradient(to top,var(--red),var(--yellow));display:block}.trend-point span{position:absolute;bottom:-24px;font:600 .58rem var(--mono);white-space:nowrap}.unavailable-chart{min-height:180px;margin-top:28px;padding:25px;background:var(--paper-deep);display:flex;flex-direction:column;justify-content:center;gap:12px}.unavailable-chart strong{font:1.35rem/1 var(--serif)}.unavailable-chart span{color:var(--muted);line-height:1.4}.visual-note{font-size:.75rem;color:var(--muted);margin:25px 0 0;line-height:1.4}.bar-list{margin-top:25px}.bar-list>div{margin:18px 0}.bar-list>div>div{display:flex;justify-content:space-between;font:600 .68rem var(--mono)}.bar-list>div>i,.region-list i{height:9px;background:var(--paper-deep);display:block;margin-top:7px}.bar-list>div>i:after{content:'';display:block;width:var(--bar);height:100%;background:var(--red)}.region-list{margin-top:25px}.region-list>div{display:grid;grid-template-columns:100px 1fr 44px;gap:10px;align-items:center;margin:15px 0;font-size:.75rem}.region-list i{margin:0}.region-list i b{display:block;height:100%;background:var(--ink)}.region-list em{font:600 .65rem var(--mono);font-style:normal;text-align:right}.visual-caveat{display:flex;gap:15px;padding:15px;background:var(--yellow);font-size:.78rem;line-height:1.35}.visual-caveat strong{font:600 .62rem var(--mono);text-transform:uppercase;white-space:nowrap}@media(max-width:700px){.key-number-row,.visual-grid{grid-template-columns:1fr}.visual-wide{grid-column:auto}.visual-heading{display:block}.visual-heading small{display:block;text-align:left;margin-top:8px}.region-list>div{grid-template-columns:82px 1fr 38px}.visual-caveat{display:block}.visual-caveat strong{margin-bottom:8px}}
</style>
