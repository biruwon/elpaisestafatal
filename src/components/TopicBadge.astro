---
import Icon from './Icon.astro';
import { getTopicPresentation } from '../data/topicPresentation';
interface Props { slug: string; compact?: boolean }
const { slug, compact = false } = Astro.props;
const topic = getTopicPresentation(slug);
---
<span class:list={['topic-badge', { compact }]} style={`--topic-color:${topic.color}`}><Icon name={topic.icon} size={compact ? 15 : 17} /><span>{topic.label}</span></span>
