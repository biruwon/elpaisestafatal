---
interface Props { title?: string; description?: string }
import { concerns } from '../data/concerns';
const { title = 'El país está fatal — datos, no trincheras', description = `${concerns.length} preocupaciones sobre España explicadas con fuentes primarias.` } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f1e8" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="stylesheet" href="/quick-answer.css" />
  </head>
  <body>
    <header class="site-header"><a class="brand" href="/"><span>el país</span><strong>está fatal</strong><i>.</i></a><nav aria-label="Principal"><a href="/verificaciones">Verificaciones</a><a href="/#preocupaciones">Las {concerns.length}</a><a href="/metodologia">Metodología</a><a href="/fuentes">Fuentes</a></nav></header>
    <main><slot /></main>
    <footer><p><strong>El país está fatal.</strong> Un proyecto independiente para mirar los datos sin trincheras.</p><div><a href="/metodologia">Metodología</a><a href="/fuentes">Fuentes</a><a href="/privacidad">Privacidad</a><a href="/contacto">Contactar</a></div></footer>
  </body>
</html>
