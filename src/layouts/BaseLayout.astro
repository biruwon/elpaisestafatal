---
interface Props { title?: string; description?: string; image?: string; pageType?: 'website'|'article' }
import { concerns } from '../data/concerns';
const { title = 'El país está fatal. ¿Seguro?', description = `Comprueba afirmaciones sobre España con ${concerns.length} investigaciones, contexto y fuentes primarias.`, image='/cards/preocupacion-vivienda.png', pageType='website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const socialImage = new URL(image, Astro.site ?? Astro.url.origin);
const cloudflareAnalyticsToken = import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f5f1e8" />
    <title>{title}</title>
    {cloudflareAnalyticsToken && <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={JSON.stringify({ token: cloudflareAnalyticsToken })}></script>}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="stylesheet" href="/foundation.css" />
    <link rel="stylesheet" href="/topic.css" />
    <link rel="stylesheet" href="/quick-answer.css" />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <header class="site-header"><a class="brand" href="/" aria-label="El país está fatal, inicio"><span>el país</span><strong>está fatal</strong><i>.</i></a><nav aria-label="Principal"><a href="/">Inicio</a><a href="/buscar">Buscar</a><a href="/acerca-de">Acerca de</a></nav></header>
    <main id="contenido"><slot /></main>
    <footer><p><strong>El país está fatal — compruébalo.</strong> Proyecto independiente, anónimo y sin financiación externa.</p><div><a href="/acerca-de">Acerca de</a><a href="/metodologia">Metodología</a><a href="/fuentes">Fuentes</a><a href="/revisiones">Revisiones</a><a href="/privacidad">Privacidad</a><a href="/contacto">Corregir</a></div></footer>
  </body>
</html>
