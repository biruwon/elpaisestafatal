---
interface Props { title?: string; description?: string; image?: string; pageType?: 'website'|'article' }
import { concerns } from '../data/concerns';
const { title = 'El país está fatal. ¿Seguro?', description = `Comprueba afirmaciones sobre España con ${concerns.length} investigaciones, contexto y fuentes primarias.`, image='/cards/preocupacion-vivienda.png', pageType='website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const socialImage = new URL(image, Astro.site ?? Astro.url.origin);
const structuredData = JSON.stringify({ '@context': 'https://schema.org', '@type': pageType === 'article' ? 'Article' : 'WebPage', name: title, description, url: canonical.toString(), image: socialImage.toString(), isPartOf: { '@type': 'WebSite', name: 'El país está fatal', url: Astro.site?.toString() ?? Astro.url.origin } });
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="El país está fatal" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script is:inline type="application/ld+json" set:html={structuredData}></script>
    <meta name="theme-color" content="#f5f1e8" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="stylesheet" href="/foundation.css" />
    <link rel="stylesheet" href="/topic.css" />
    <link rel="stylesheet" href="/home.css" />
    <link rel="stylesheet" href="/quick-answer.css" />
    <style>.site-header nav{max-width:min(70vw,720px);overflow-x:auto;white-space:nowrap;scrollbar-width:none}.site-header nav::-webkit-scrollbar{display:none}@media(max-width:700px){.site-header{gap:14px}.site-header nav{max-width:68vw;gap:14px;font-size:.64rem}}</style>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <header class="site-header"><a class="brand" href="/" aria-label="El país está fatal, inicio"><span>el país</span><strong>está fatal</strong><i>.</i></a><nav aria-label="Principal"><a href="/">Inicio</a><a href="/buscar">Buscar</a><a href="/afirmaciones">Afirmaciones</a><a href="/investigaciones">Investigaciones</a></nav></header>
    <main id="contenido"><slot /></main>
    <footer><p><strong>El país está fatal — compruébalo.</strong> Proyecto independiente, anónimo y sin financiación externa.</p></footer>
    <script is:inline>
      document.addEventListener('click', async (event) => { const link = event.target.closest('a'); if (!link || link.textContent.trim() !== 'Copiar enlace') return; event.preventDefault(); try { await navigator.clipboard.writeText(location.href); link.textContent = 'Enlace copiado'; } catch { link.textContent = 'Selecciona el enlace en la barra del navegador'; } });
    </script>
  </body>
</html>
