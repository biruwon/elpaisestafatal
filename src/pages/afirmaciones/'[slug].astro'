---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicBadge from '../../components/TopicBadge.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ExpandableSection from '../../components/ExpandableSection.astro';
import ActionLink from '../../components/ActionLink.astro';
import { claims, getClaim, assessmentLabels } from '../../data/claims';
import { concerns } from '../../data/concerns';
export function getStaticPaths(){return claims.map((item)=>({params:{slug:item.slug}}));}
const item=getClaim(Astro.params.slug!); if(!item)return Astro.redirect('/afirmaciones');
const related=claims.filter((claim)=>claim.slug!==item.slug&&(claim.topicSlug===item.topicSlug||claim.keywords.some((keyword)=>item.keywords.includes(keyword)))).slice(0,6);
const concern=concerns.find((entry)=>entry.slug===item.topicSlug);
---
<BaseLayout title={`${item.claim} — El país está fatal`} description={item.shareable} image={`/cards/${item.slug}.png`} pageType="article"><article class="affirmation-page"><Breadcrumbs items={[{label:'Afirmaciones',href:'/afirmaciones'},{label:item.claim.replace(/[“”]/g,'')}]} /><header class="affirmation-hero"><TopicBadge slug={item.topicSlug} /><p class="eyebrow">Afirmación comprobada</p><h1>{item.claim.replace(/[“”]/g,'')}</h1><strong class={`assessment assessment-${item.assessment}`}>{assessmentLabels[item.assessment]}</strong><p class="answer-line">{item.shareable}</p><div class="learn-meta"><span>Lectura: 60 segundos</span><span>Revisado: 12 jul. 2026</span></div></header><section class="affirmation-visual"><img src={`/cards/${item.slug}.png`} alt="" width="1080" height="1080" loading="eager" /><div><p class="eyebrow">Qué aprenderás</p><p>Qué parte de la afirmación encaja con los datos, qué contexto falta y qué no puede probar esta comparación.</p><ActionLink href="#evidencia" label="Ir a la evidencia" /></div></section><section id="evidencia" class="claim-facts"><header class="section-header section-header-left"><p class="eyebrow">La respuesta breve</p><h2>Lo que es cierto<br /><em>y lo que falta.</em></h2></header><div class="fact-grid"><article><p class="eyebrow">Qué es cierto</p><p>{item.whatIsTrue}</p></article><article><p class="eyebrow">Qué falta</p><p>{item.whatIsMissing}</p></article><article><p class="eyebrow">Escala relevante</p><p>{item.scale}</p></article><article><p class="eyebrow">Límite de los datos</p><p>{item.cannotProve}</p></article></div></section><blockquote class="share-response">{item.shareable}</blockquote><div class="claim-actions"><button type="button" data-copy>Responder con esto</button><button type="button" data-share>Compartir</button><a href={Astro.url.pathname}>Enlace directo</a><a href={`/cards/${item.slug}.png`} download>Tarjeta PNG</a><span aria-live="polite"></span></div>{concern?.investigation && <ExpandableSection summary="Leer la investigación completa"><p>{concern.investigation.standfirst}</p><p><a href={`/preocupaciones/${concern.slug}`}>Abrir el tema completo sobre {concern.title} →</a></p></ExpandableSection>}<section class="claim-sources"><p class="eyebrow">Fuentes originales</p>{item.sources.map((source,index)=><a href={source.url} target="_blank" rel="noreferrer"><span>{String(index+1).padStart(2,'0')}</span><strong>{source.label}</strong><small>{source.publisher} · {source.date} ↗</small></a>)}</section>{related.length>0&&<section class="related-claims"><header class="section-header section-header-left"><p class="eyebrow">Sigue comprobando</p><h2>Preguntas<br /><em>relacionadas.</em></h2></header><div>{related.map((claim)=><a href={`/afirmaciones/${claim.slug}`}><TopicBadge slug={claim.topicSlug} compact /><strong>{claim.claim.replace(/[“”]/g,'')}</strong></a>)}</div></section>}</article><script>const actions=document.querySelector<HTMLElement>('.claim-actions');const announce=(message:string)=>{const live=actions?.querySelector<HTMLElement>('[aria-live]');if(live)live.textContent=message};const copy=async(value:string,message:string)=>{await navigator.clipboard.writeText(value);announce(message)};actions?.querySelector('[data-copy]')?.addEventListener('click',()=>copy(`${document.querySelector('.share-response')?.textContent?.trim()} ${location.href}`,'Respuesta copiada'));actions?.querySelector('[data-share]')?.addEventListener('click',async()=>{if(navigator.share)await navigator.share({title:document.title,text:document.querySelector('.share-response')?.textContent?.trim(),url:location.href});else await copy(location.href,'Enlace copiado')});</script></BaseLayout>
<style>.affirmation-page{max-width:1120px;margin:auto;padding:45px 30px 100px}.affirmation-hero{padding:70px 0 55px;border-bottom:1px solid var(--ink)}.affirmation-hero h1{font:400 clamp(3.2rem,7vw,7rem)/.86 var(--serif);letter-spacing:-.07em;max-width:1000px;margin:22px 0 30px}.assessment{display:inline-block;padding:9px 13px;background:var(--yellow);font:.7rem var(--mono);text-transform:uppercase}.assessment-false{background:#f1b4aa}.assessment-true,.assessment-mostly-true{background:#cfe5cb}.answer-line{font:clamp(1.35rem,2.3vw,2.1rem)/1.15 var(--serif);max-width:760px;margin:35px 0 20px}.learn-meta{display:flex;gap:20px;flex-wrap:wrap;color:var(--muted);font:.65rem var(--mono);text-transform:uppercase}.affirmation-visual{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(220px,.75fr);gap:60px;align-items:center;padding:65px 0;border-bottom:1px solid var(--line)}.affirmation-visual img{width:100%;height:auto;background:var(--paper-deep)}.affirmation-visual p:not(.eyebrow){font:1.3rem/1.3 var(--serif);margin-bottom:30px}.claim-facts{padding:90px 0 55px}.fact-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line)}.fact-grid article{background:var(--paper);padding:28px;min-height:190px}.fact-grid article>p:last-child{font:1.3rem/1.3 var(--serif)}.share-response{margin:40px 0 18px;padding:24px 28px;border-left:5px solid var(--red);background:var(--paper-deep);font:1.35rem/1.3 var(--serif)}.claim-actions{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:55px}.claim-actions button,.claim-actions a{border:1px solid var(--ink);background:transparent;padding:10px 12px;font:600 .65rem var(--mono);cursor:pointer}.claim-actions span{width:100%;color:var(--red);font:.65rem var(--mono)}.claim-sources{padding:70px 0;border-top:1px solid var(--line);margin-top:55px}.claim-sources>a{display:grid;grid-template-columns:40px 1fr;gap:4px 12px;padding:15px 0;border-bottom:1px solid var(--line)}.claim-sources>a>span{font:.65rem var(--mono);color:var(--red)}.claim-sources strong{font:1.15rem var(--serif)}.claim-sources small{grid-column:2;color:var(--muted);font-size:.68rem}.related-claims{border-top:1px solid var(--line);padding-top:70px;margin-top:20px}.related-claims>div{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line)}.related-claims a{background:var(--paper);padding:22px;min-height:140px}.related-claims a:hover{background:var(--paper-deep)}.related-claims strong{display:block;font:1.3rem/1 var(--serif);margin-top:22px}@media(max-width:700px){.affirmation-page{padding:30px 20px 70px}.affirmation-visual{grid-template-columns:1fr;gap:30px}.fact-grid,.related-claims>div{grid-template-columns:1fr}.claim-sources>a{grid-template-columns:28px 1fr}.claim-sources small{grid-column:2}}
</style>
