---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicBadge from '../../components/TopicBadge.astro';
import { claims, assessmentLabels } from '../../data/claims';
---
<BaseLayout title="Afirmaciones — El país está fatal" description="Afirmaciones sobre España comprobadas con contexto y fuentes originales."><article class="prose affirmation-index"><p class="eyebrow">Catálogo editorial</p><h1>Afirmaciones,<br /><em>puestas a prueba.</em></h1><p class="lead">Preguntas concretas para conversaciones concretas. Cada respuesta enlaza los datos y explica lo que no permiten concluir.</p><div class="affirmation-grid">{claims.map((item) => <a href={`/afirmaciones/${item.slug}`}><TopicBadge slug={item.topicSlug} compact /><h2>{item.claim.replace(/[“”]/g,'')}</h2><span>{assessmentLabels[item.assessment]} →</span></a>)}</div></article></BaseLayout>
<style>.affirmation-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line);margin-top:55px}.affirmation-grid a{background:var(--paper);padding:24px;min-height:190px}.affirmation-grid a:hover{background:var(--paper-deep)}.affirmation-grid h2{font:400 1.7rem/1 var(--serif);letter-spacing:-.04em;margin:28px 0}.affirmation-grid a>span:last-child{font:600 .65rem var(--mono);color:var(--red)}@media(max-width:650px){.affirmation-grid{grid-template-columns:1fr}}
</style>
