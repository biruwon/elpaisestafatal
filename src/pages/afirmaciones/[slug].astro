---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicBadge from '../../components/TopicBadge.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ActionLink from '../../components/ActionLink.astro';
import ClaimActions from '../../components/ClaimActions.astro';
import { claims, getClaim, assessmentLabels } from '../../data/claims';
import { concerns } from '../../data/concerns';

export function getStaticPaths(){return claims.filter((claim)=>claim.published).map((item)=>({params:{slug:item.slug}}));}
const item=getClaim(Astro.params.slug!); if(!item || !item.published)return Astro.redirect('/afirmaciones');
const relatedSlugs=new Set(item.relatedSlugs);
const related=claims.filter((claim)=>claim.published&&claim.slug!==item.slug&&(relatedSlugs.has(claim.slug)||claim.topicSlugs.some((slug)=>item.topicSlugs.includes(slug))||claim.keywords.some((keyword)=>item.keywords.includes(keyword)))).slice(0,6);
const concern=concerns.find((entry)=>item.topicSlugs.includes(entry.slug));
const metrics=concern?.dossier.metrics.slice(0,3) ?? [];
const series=concern?.dossier.series;
const chartMax=series ? Math.max(...series.values.map(Math.abs),1) : 1;
const assessmentTone=item.assessment;
---
<BaseLayout title={`${item.claim} — El país está fatal`} description={item.shareable} image={`/cards/${item.slug}.png`} pageType="article">
  <article id="claim-top" class="affirmation-page">
    <Breadcrumbs items={[{label:'Afirmaciones',href:'/afirmaciones'},{label:item.claim.replace(/[“”]/g,'')}]}/>
    <header class="affirmation-hero">
      <div class="claim-topics">{item.topicSlugs.map((slug)=><TopicBadge slug={slug}/>)}</div>
      <p class="eyebrow">Afirmación comprobada</p>
      <h1>{item.claim.replace(/[“”]/g,'')}</h1>
      <strong class={`assessment assessment-${assessmentTone}`}>{assessmentLabels[item.assessment]}</strong>
      <p class="answer-line">{item.shareable}</p>
      <div class="learn-meta"><span>Tipo: {item.claimType}</span><span>Evidencia: {item.evidenceStrength}</span><span>Geografía: {item.geography}</span><span>Periodo: {item.period}</span><span>Revisado: {item.reviewed}</span></div>
    </header>
    <nav class="claim-reading-nav" aria-label="Niveles de lectura"><a href="#claim-answer">Respuesta rápida</a><a href="#claim-data">Datos</a><a href="#claim-context">Contexto</a><a href="#claim-sources">Fuentes</a></nav>
    <section id="claim-answer" class="claim-visual" aria-label="Respuesta visual"><div class="claim-visual-copy"><p class="eyebrow">En diez segundos</p><strong>{item.shareable}</strong><span>{item.decisiveEvidence}</span></div><div class="claim-visual-mark" aria-hidden="true"><i></i><i></i><i></i><b>{assessmentLabels[item.assessment]}</b></div></section>
    <section id="claim-data" class="claim-data"><header class="section-header section-header-split"><div><p class="eyebrow">La escala en datos</p><h2>Entenderlo<br /><em>sin perderse.</em></h2></div><p class="section-header-description">Estos datos sitúan la afirmación en el contexto de su tema. La cifra no sustituye la explicación ni prueba una causa por sí sola.</p></header>{metrics.length>0&&<div class="claim-metrics">{metrics.map((metric)=><article><strong>{metric.value}</strong><span>{metric.label}</span></article>)}</div>}{series&&<figure class="claim-chart"><figcaption><strong>{series.label}</strong><span>{series.unit}</span></figcaption>{series.values.slice(-5).map((value,index)=><div><span>{series.labels.slice(-5)[index]}</span><i><b style={`width:${Math.max(4,Math.abs(value)/chartMax*100)}%`}></b></i><strong>{String(value).replace('.',',')}</strong></div>)}<small>Fuente y límites: la serie pertenece a la investigación del tema.</small></figure>}</section>
    <section class="claim-facts"><header class="section-header section-header-left"><p class="eyebrow">La respuesta breve</p><h2>Lo que es cierto<br /><em>y lo que falta.</em></h2></header><div class="fact-grid"><article><p class="eyebrow">Qué es cierto</p><p>{item.whatIsTrue}</p></article><article><p class="eyebrow">Qué falta</p><p>{item.whatIsMissing}</p></article><article><p class="eyebrow">Evidencia decisiva</p><p>{item.decisiveEvidence}</p></article><article><p class="eyebrow">Límite de los datos</p><p>{item.cannotProve}</p></article></div><aside class="key-callout"><p class="eyebrow">La clave</p><strong>Una diferencia en los datos no demuestra por sí sola cuál es la causa.</strong></aside></section>
    <section id="claim-context" class="claim-context"><header class="section-header section-header-left"><p class="eyebrow">Contexto editorial</p><h2>Causas,<br /><em>límites y cambios.</em></h2></header><div class="context-grid"><article><p class="eyebrow">Por qué circula</p><p>{item.whyItCirculates}</p></article><article><p class="eyebrow">Qué no sabemos</p><p>{item.unknowns}</p></article><article><p class="eyebrow">Qué cambiaría la conclusión</p><p>{item.evidenceCouldChange}</p></article><article><p class="eyebrow">Explicaciones rivales</p>{item.competingExplanations.length?<ul>{item.competingExplanations.map((explanation)=><li>{explanation}</li>)}</ul>:<p>La ficha actual no separa explicaciones rivales adicionales; la investigación completa desarrolla el contexto causal.</p>}</article></div></section>
    <ClaimActions short={item.shareable} context={`${item.whatIsTrue} ${item.whatIsMissing}`} data={`${item.scale} ${item.cannotProve}`} imageHref={`/cards/${item.slug}.png`} />
    {concern?.investigation&&<section class="deep-link"><div><p class="eyebrow">Investigación completa</p><h2>{concern.investigation.title}</h2><p>{concern.investigation.standfirst}</p></div><ActionLink href={`/preocupaciones/${concern.slug}`} label="Leer la investigación completa" variant="button" /></section>}
    <section id="claim-sources" class="claim-sources"><p class="eyebrow">Fuentes originales</p>{item.sources.map((source,index)=><a href={source.url} target="_blank" rel="noreferrer"><span>{String(index+1).padStart(2,'0')}</span><strong>{source.label}</strong><small>{source.publisher} · {source.date} ↗</small></a>)}<small class="evidence-note">Objetos de evidencia: {item.evidenceIds.join(' · ')}</small></section>
    {related.length>0&&<section class="related-claims"><header class="section-header section-header-left"><p class="eyebrow">Sigue comprobando</p><h2>Preguntas<br /><em>relacionadas.</em></h2></header><div>{related.map((claim,index)=><a class:list={{'featured-next':index===0}} href={`/afirmaciones/${claim.slug}`}><TopicBadge slug={claim.topicSlugs[0]} compact/><strong>{index===0?'Siguiente pregunta · ':''}{claim.claim.replace(/[“”]/g,'')}</strong></a>)}</div></section>}
  </article>
</BaseLayout>
<style>
  .affirmation-page{max-width:1120px;margin:auto;padding:45px 30px 100px}.affirmation-hero{padding:70px 0 55px;border-bottom:1px solid var(--ink)}.claim-topics{display:flex;gap:8px;flex-wrap:wrap}.affirmation-hero h1{font:400 clamp(3.2rem,7vw,7rem)/.86 var(--serif);letter-spacing:-.07em;max-width:1000px;margin:22px 0 30px}.assessment{display:inline-block;padding:9px 13px;background:var(--yellow);font:.7rem var(--mono);text-transform:uppercase}.assessment-false{background:#f1b4aa}.assessment-true,.assessment-mostly-true{background:#cfe5cb}.answer-line{font:clamp(1.35rem,2.3vw,2.1rem)/1.15 var(--serif);max-width:760px;margin:35px 0 20px}.learn-meta{display:flex;gap:12px 20px;flex-wrap:wrap;color:var(--muted);font:.65rem var(--mono);text-transform:uppercase}.claim-reading-nav{display:flex;gap:8px;flex-wrap:wrap;padding:14px 0;border-bottom:1px solid var(--line);position:sticky;top:0;background:color-mix(in srgb,var(--paper) 94%,transparent);backdrop-filter:blur(8px);z-index:3}.claim-reading-nav a{border:1px solid var(--ink);padding:9px 11px;font:600 .64rem var(--mono)}.claim-reading-nav a:hover{background:var(--ink);color:var(--paper)}.claim-visual{display:grid;grid-template-columns:1.4fr .6fr;gap:35px;align-items:stretch;margin:55px 0 0;background:var(--ink);color:var(--paper);min-height:330px}.claim-visual-copy{padding:38px;display:flex;flex-direction:column;align-items:flex-start}.claim-visual-copy strong{font:400 clamp(2rem,4vw,4.2rem)/.92 var(--serif);letter-spacing:-.05em;margin:20px 0 auto;max-width:700px}.claim-visual-copy>span{font:.8rem/1.45 var(--sans);color:#d5cec3;max-width:550px}.claim-visual-mark{background:var(--red);display:flex;flex-direction:column;justify-content:center;align-items:center;gap:14px;position:relative;padding:25px}.claim-visual-mark i{display:block;width:75%;height:12px;background:var(--yellow);transform:skewY(-18deg)}.claim-visual-mark i:nth-child(2){width:55%;opacity:.8}.claim-visual-mark i:nth-child(3){width:35%;opacity:.6}.claim-visual-mark b{font:600 .68rem var(--mono);text-transform:uppercase;margin-top:24px}.claim-data,.claim-facts,.claim-context{padding:90px 0 65px;border-bottom:1px solid var(--line)}.claim-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin-top:35px}.claim-metrics article{background:var(--paper-deep);padding:28px}.claim-metrics strong{display:block;font:400 clamp(2.3rem,4vw,4rem)/.9 var(--serif);color:var(--red);letter-spacing:-.06em}.claim-metrics span{display:block;margin-top:12px;font:.72rem/1.3 var(--mono)}.claim-chart{background:var(--paper-deep);padding:25px;margin:28px 0 0}.claim-chart figcaption{display:flex;justify-content:space-between;gap:20px;margin-bottom:25px;font:.72rem var(--mono);text-transform:uppercase}.claim-chart figcaption span{color:var(--muted)}.claim-chart>div{display:grid;grid-template-columns:80px 1fr 55px;gap:12px;align-items:center;margin:12px 0;font:.7rem var(--mono)}.claim-chart i{height:14px;background:#d2c8ba}.claim-chart i b{display:block;height:100%;background:var(--red)}.claim-chart small,.evidence-note{display:block;color:var(--muted);font:.68rem/1.45 var(--mono);margin-top:18px}.fact-grid,.context-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line)}.fact-grid article,.context-grid article{background:var(--paper);padding:28px;min-height:190px}.fact-grid article>p:last-child,.context-grid article>p:last-child{font:1.3rem/1.3 var(--serif)}.context-grid ul{padding-left:18px;line-height:1.5}.key-callout{margin-top:28px;padding:24px;border-left:5px solid var(--red);background:var(--paper-deep)}.key-callout strong{font:1.45rem/1.2 var(--serif)}.deep-link{display:flex;justify-content:space-between;gap:35px;align-items:center;padding:35px 0;border-top:2px solid var(--ink);border-bottom:1px solid var(--line);margin-top:40px}.deep-link h2{font:2.2rem/.95 var(--serif);margin:0 0 10px}.deep-link p:not(.eyebrow){max-width:650px;color:var(--muted);margin:0}.claim-sources{padding:70px 0;border-top:1px solid var(--line);margin-top:55px}.claim-sources>a{display:grid;grid-template-columns:40px 1fr;gap:4px 12px;padding:15px 0;border-bottom:1px solid var(--line)}.claim-sources>a>span{font:.65rem var(--mono);color:var(--red)}.claim-sources strong{font:1.15rem var(--serif)}.claim-sources small{grid-column:2;color:var(--muted);font-size:.68rem}.related-claims{border-top:1px solid var(--line);padding-top:70px;margin-top:20px}.related-claims>div{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line)}.related-claims a{background:var(--paper);padding:22px;min-height:140px}.related-claims a:hover{background:var(--paper-deep)}.related-claims a.featured-next{grid-column:1/-1;background:var(--paper-deep)}.related-claims strong{display:block;font:1.3rem/1 var(--serif);margin-top:22px}@media(max-width:700px){.affirmation-page{padding:30px 20px 70px}.claim-visual{grid-template-columns:1fr;margin-left:-20px;margin-right:-20px}.claim-visual-copy{padding:28px 20px;min-height:310px}.claim-visual-copy strong{font-size:2.5rem}.claim-visual-mark{min-height:150px}.claim-data,.claim-facts,.claim-context{padding:65px 0 45px}.claim-metrics,.fact-grid,.context-grid,.related-claims>div{grid-template-columns:1fr}.claim-chart>div{grid-template-columns:60px 1fr 45px}.deep-link{display:block}.deep-link .action-link{margin-top:24px}.claim-sources>a{grid-template-columns:28px 1fr}.claim-sources small{grid-column:2}}
</style>
