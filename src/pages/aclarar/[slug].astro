---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClarifierVisuals from '../../components/ClarifierVisuals.astro';
import { conversationMvpClaims } from '../../data/conversationMvp';

export function getStaticPaths() {
  return conversationMvpClaims.map((claim) => ({ params: { slug: claim.slug }, props: { claim } }));
}

const { claim } = Astro.props;
const sourceClaim = `/afirmaciones/${claim.slug}`;
---
<BaseLayout title={`${claim.prompt} — Aclaración`} description="Una aclaración breve con contexto, datos y límites de la evidencia.">
  <article class="clarifier-page">
    <noscript><p class="noscript-notice">Esta aclaración funciona mejor con JavaScript activado. <a href={sourceClaim}>Consulta directamente la investigación y sus fuentes.</a></p></noscript>
    <a class="back-link" href="/">← Volver a las discusiones</a>
    <header class="clarifier-hero">
      <p class="eyebrow">Aclaración rápida · España</p>
      <h1>{claim.prompt}</h1>
      <p class="hero-answer">Esta frase mezcla varias preguntas. Aquí separamos lo que puede ser cierto, lo que muestran los datos y lo que todavía no permiten concluir.</p>
    </header>

    <section class="clarifier-section split-section">
      <div><p class="eyebrow">1 · Qué se está afirmando</p><h2>No es una sola pregunta.</h2></div>
      <div class="proposition-list">{claim.propositions.map((proposition, index) => <div><span>0{index + 1}</span><p>{proposition}</p></div>)}</div>
    </section>

    <section class="clarifier-section">
      <div class="section-intro"><p class="eyebrow">2 · La evidencia decisiva</p><h2>Lo que sabemos<br /><em>hasta ahora.</em></h2><p>{claim.supports}</p></div>
      <ClarifierVisuals claim={claim} />
      <div class="evidence-grid"><div class="evidence-card"><span class="card-kicker">Lo que sí apoya</span><p>{claim.supports}</p><span class="evidence-strength">Evidencia directa</span></div><div class="evidence-card evidence-card-muted"><span class="card-kicker">Lo que no demuestra</span><p>{claim.limit}</p><span class="evidence-strength">Límite importante</span></div></div>
    </section>

    <section class="clarifier-section two-column-section">
      <div><p class="eyebrow">3 · La preocupación real</p><h2>La experiencia puede ser válida aunque la explicación no esté demostrada.</h2><p>{claim.concern}</p></div>
      <div class="question-card"><span class="card-kicker">La pregunta que aclara el debate</span><strong>{claim.question}</strong><p>Una buena pregunta concreta el lugar, el periodo, la población y la definición que necesitamos medir.</p></div>
    </section>

    <section class="clarifier-section reply-section">
      <p class="eyebrow">4 · Una respuesta para compartir</p><h2>No hace falta ganar la discusión.</h2><div class="share-response"><p>“{claim.reply}”</p><button type="button" id="copy-response">Copiar respuesta</button></div><p id="copy-status" class="copy-status" aria-live="polite"></p>
    </section>

    <section class="clarifier-section uncertainty-section"><div><p class="eyebrow">5 · Lo que sigue abierto</p><h2>Qué podría cambiar<br /><em>esta conclusión.</em></h2></div><div><p>{claim.limit}</p><p class="future-evidence"><strong>Para afinarla harían falta:</strong> datos más específicos del territorio, una definición común y una comparación que mida el mismo fenómeno durante el mismo periodo.</p></div></section>

    <footer class="clarifier-footer"><a href={sourceClaim}>Ver la investigación y todas las fuentes →</a><a href="/">Comprobar otra afirmación →</a></footer>
  </article>
</BaseLayout>
<script is:inline>
  const copyButton=document.querySelector('#copy-response');const copyStatus=document.querySelector('#copy-status');copyButton?.addEventListener('click',async()=>{try{await navigator.clipboard.writeText(copyButton.parentElement?.querySelector('p')?.textContent?.replace(/[“”]/g,'')||'');copyButton.textContent='Respuesta copiada';if(copyStatus)copyStatus.textContent='Ya puedes pegarla en tu conversación.';}catch{if(copyStatus)copyStatus.textContent='No se pudo copiar automáticamente; selecciona el texto.';}});
</script>
<style>
  .clarifier-page{max-width:1180px;margin:0 auto;padding:40px 24px 90px}.noscript-notice{border:1px solid var(--line);padding:14px;background:var(--paper-deep);font-size:.85rem}.back-link{font:600 .68rem var(--mono);color:var(--muted)}.clarifier-hero{max-width:900px;padding:90px 0 80px}.clarifier-hero h1{font:400 clamp(3rem,7vw,7.5rem)/.86 var(--serif);letter-spacing:-.07em;margin:18px 0 28px}.hero-answer{font:1.35rem/1.35 var(--serif);max-width:680px}.clarifier-section{border-top:1px solid var(--line);padding:75px 0}.split-section,.two-column-section,.uncertainty-section{display:grid;grid-template-columns:1fr 1fr;gap:70px}.clarifier-section h2{font:400 clamp(2.4rem,4vw,4.8rem)/.9 var(--serif);letter-spacing:-.06em;margin:0 0 24px}.clarifier-section p{line-height:1.5}.proposition-list{border-top:2px solid var(--ink)}.proposition-list div{display:grid;grid-template-columns:45px 1fr;gap:15px;border-bottom:1px solid var(--line);padding:17px 0}.proposition-list span{font:600 .7rem var(--mono);color:var(--red)}.proposition-list p{margin:0;font:1.25rem/1.15 var(--serif)}.section-intro{max-width:560px;margin-bottom:35px}.section-intro>p:last-child{font-size:1.1rem}.evidence-grid{display:grid;grid-template-columns:1.35fr 1fr 1fr;gap:1px;background:var(--line)}.evidence-card{background:var(--paper);padding:25px;min-height:220px;display:flex;flex-direction:column}.evidence-card-large{grid-row:span 2}.card-kicker,.clarification-label{font:600 .63rem var(--mono);text-transform:uppercase;color:var(--red);display:block}.evidence-card strong{font:1.6rem/1 var(--serif);margin:20px 0}.evidence-card p{font:1.05rem/1.35 var(--serif);margin:20px 0 auto}.evidence-card small{color:var(--muted);line-height:1.4}.evidence-card-muted{background:var(--paper-deep)}.evidence-strength{font:600 .65rem var(--mono);text-transform:uppercase;margin-top:25px}.mock-chart{height:170px;display:flex;align-items:end;gap:12px;border-bottom:1px solid var(--ink);padding:20px 15px 0;margin:10px 0 18px}.mock-chart i{display:block;flex:1;background:var(--red);opacity:.78}.question-card{background:var(--yellow);padding:30px;align-self:start}.question-card strong{display:block;font:1.8rem/1 var(--serif);margin:20px 0}.reply-section{max-width:880px}.share-response{border:2px solid var(--ink);padding:28px;background:var(--paper-deep)}.share-response p{font:1.5rem/1.3 var(--serif);margin:0 0 24px}.share-response button{background:var(--ink);color:var(--paper);border:0;padding:13px 18px;font:600 .68rem var(--mono);cursor:pointer}.copy-status{color:var(--red);font:600 .7rem var(--mono)}.future-evidence{border-left:3px solid var(--yellow);padding-left:20px}.clarifier-footer{border-top:2px solid var(--ink);padding-top:20px;display:flex;justify-content:space-between;gap:20px;font:600 .7rem var(--mono)}.clarifier-footer a:first-child{color:var(--red)}@media(max-width:700px){.clarifier-page{padding:25px 20px 65px}.clarifier-hero{padding:65px 0}.clarifier-hero h1{font-size:3.5rem}.hero-answer{font-size:1.15rem}.split-section,.two-column-section,.uncertainty-section{grid-template-columns:1fr;gap:30px;padding:55px 0}.evidence-grid{grid-template-columns:1fr}.evidence-card-large{grid-row:auto}.evidence-card{min-height:0}.clarifier-footer{flex-direction:column}.proposition-list p{font-size:1.1rem}}
</style>
<style>
.key-number-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin-bottom:1px}.key-number{background:var(--paper);padding:24px;display:flex;flex-direction:column}.key-number strong{font:400 clamp(2.6rem,5vw,5rem)/.85 var(--serif);color:var(--red);letter-spacing:-.06em}.key-number span{font:1rem/1.15 var(--serif);margin-top:14px}.key-number small{font:600 .62rem var(--mono);text-transform:uppercase;margin-top:auto;padding-top:20px;color:var(--muted)}.visual-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line)}.visual-card{background:var(--paper);padding:24px;min-height:260px}.visual-wide{grid-column:span 2}.visual-heading{display:flex;justify-content:space-between;gap:20px}.visual-heading strong{display:block;font:1.35rem/1 var(--serif);margin-top:10px}.visual-heading small{font:600 .62rem var(--mono);text-transform:uppercase;color:var(--muted);text-align:right}.trend-chart{height:180px;display:flex;align-items:end;gap:8px;border-bottom:1px solid var(--ink);margin-top:28px;padding:0 8px}.trend-point{height:100%;flex:1;position:relative;display:flex;align-items:end}.trend-point i{height:var(--point);width:100%;background:linear-gradient(to top,var(--red),var(--yellow));display:block}.trend-point span{position:absolute;bottom:-24px;font:600 .58rem var(--mono);white-space:nowrap}.visual-note{font-size:.75rem;color:var(--muted);margin:40px 0 0}.bar-list{margin-top:25px}.bar-list>div{margin:18px 0}.bar-list>div>div{display:flex;justify-content:space-between;font:600 .68rem var(--mono)}.bar-list>div>i,.region-list i{height:9px;background:var(--paper-deep);display:block;margin-top:7px}.bar-list>div>i:after{content:'';display:block;width:var(--bar);height:100%;background:var(--red)}.region-list{margin-top:25px}.region-list>div{display:grid;grid-template-columns:100px 1fr 32px;gap:10px;align-items:center;margin:15px 0;font-size:.75rem}.region-list i{margin:0}.region-list i b{display:block;height:100%;background:var(--ink)}.region-list em{font:600 .65rem var(--mono);font-style:normal;text-align:right}.visual-caveat{display:flex;gap:15px;padding:15px;background:var(--yellow);font-size:.78rem;line-height:1.35}.visual-caveat strong{font:600 .62rem var(--mono);text-transform:uppercase;white-space:nowrap}@media(max-width:700px){.key-number-row,.visual-grid,.evidence-grid{grid-template-columns:1fr}.visual-wide{grid-column:auto}.visual-heading{display:block}.visual-heading small{display:block;text-align:left;margin-top:8px}.region-list>div{grid-template-columns:82px 1fr 28px}}
</style>
