---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contactar — El país está fatal"><article class="prose contact"><p class="eyebrow">Contactar</p><h1>Una corrección,<br /><em>una fuente, una idea.</em></h1><p class="lead">El correo no se publica. Cuando configuremos el dominio, este formulario enviará el mensaje al buzón privado del proyecto.</p><form method="post" action="/api/contact"><label>Tu correo (opcional)<input type="email" name="email" autocomplete="email" /></label><label>Mensaje<textarea name="message" required rows="6" minlength="10"></textarea></label><div class="cf-turnstile" data-sitekey="REPLACE_WITH_TURNSTILE_SITE_KEY"></div><input class="honeypot" name="company" tabindex="-1" autocomplete="off" /><button class="button" type="submit">Enviar mensaje <span>→</span></button></form></article><script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script></BaseLayout>
