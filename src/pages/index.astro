---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicBadge from '../components/TopicBadge.astro';
import ActionLink from '../components/ActionLink.astro';
import { concerns } from '../data/concerns';
import { popularClaims } from '../data/popularClaims';
const statusLabels = {'full-investigation':'Investigación completa','data-briefing':'Informe de datos','in-progress':'En preparación'} as const;
---
<BaseLayout description="Comprueba afirmaciones sobre España con datos públicos, contexto y fuentes originales.">
  <section class="homepage-hero">
    <div class="hero-copy-block"><p class="eyebrow">Datos, contexto y fuentes originales</p><h1>El país está fatal.<br /><em>¿Seguro?</em></h1><p class="hero-copy">Una pregunta antes de compartir. Comprueba qué se sabe, qué falta y qué no permite concluir cada dato.</p><ActionLink href="/buscar" label="Buscar una afirmación" variant="button" /></div>
    <p class="hero-side-note"><strong>{concerns.length}</strong><span>temas investigados<br />con fuentes abiertas</span></p>
  </section>
  <section id="afirmaciones" class="popular-home"><header class="section-header section-header-split"><div><p class="eyebrow">Afirmaciones populares</p><h2>Empieza por una<br /><em>pregunta concreta.</em></h2></div><p class="section-header-description">Preguntas frecuentes, respuestas breves y enlaces a la evidencia. No son un ranking ni una encuesta de popularidad.</p></header><div class="popular-grid">{popularClaims.map((item) => <a class="popular-card" href={`/afirmaciones/${item.slug}`}><TopicBadge slug={item.topicSlug} compact /><h3>{item.claim.replace(/[“”]/g,'')}</h3><span class="card-arrow">Comprobar <span aria-hidden="true">→</span></span></a>)}</div><ActionLink href="/afirmaciones" label="Ver todas las afirmaciones" /></section>
  <section id="temas" class="topics-home"><header class="section-header section-header-split"><div><p class="eyebrow">Temas</p><h2>Los problemas<br /><em>de fondo.</em></h2></div><p class="section-header-description">Cada tema declara su profundidad editorial. Las tarjetas no presentan todos los asuntos como igualmente completos.</p></header><ol class="topic-list">{concerns.map((item) => <li><a href={`/preocupaciones/${item.slug}`}><div><span class={`content-status status-${item.status}`}>{statusLabels[item.status]}</span><h3>{item.title}</h3><p>{item.short}</p></div><span class="topic-arrow" aria-hidden="true">↗</span></a></li>)}</ol><aside class="next-up"><p class="eyebrow">Próximas ampliaciones</p><p><a href="/preocupaciones/problemas-sociales">Problemas sociales</a> y <a href="/preocupaciones/crisis-valores">crisis de valores</a> están en fase de definición y desagregación.</p></aside></section>
  <section class="home-method"><p class="eyebrow">Cómo trabajamos</p><h2>La respuesta no termina<br /><em>en nuestro veredicto.</em></h2><p>Fuentes originales, cálculos reproducibles, interpretación separada y correcciones públicas.</p><ActionLink href="/metodologia" label="Conocer el método" /></section>
</BaseLayout>
<style>
  .homepage-hero{min-height:680px;padding:clamp(90px,14vw,180px) clamp(20px,12vw,190px) 80px;position:relative;border-bottom:1px solid var(--line)}.homepage-hero h1{font:400 clamp(3.8rem,8.5vw,8.3rem)/.82 var(--serif);letter-spacing:-.07em;margin:0;max-width:1000px}.homepage-hero h1 em{font-weight:400}.hero-copy-block{max-width:900px}.hero-copy{max-width:460px;font-size:1.08rem;line-height:1.55;margin:38px 0 30px;color:#3f3c36}.hero-side-note{position:absolute;right:clamp(20px,10vw,150px);bottom:85px;max-width:250px;border-top:2px solid var(--red);padding-top:12px;display:grid;grid-template-columns:70px 1fr;gap:3px}.hero-side-note strong{font:400 4rem/.8 var(--serif)}.hero-side-note span{font:.68rem var(--mono);text-transform:uppercase}.popular-home,.topics-home{padding:clamp(70px,10vw,130px) clamp(20px,7vw,110px);border-bottom:1px solid var(--line)}.popular-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);margin-bottom:35px}.popular-card{background:var(--paper);min-height:250px;padding:25px;display:flex;flex-direction:column;align-items:flex-start;transition:background .2s}.popular-card:hover{background:var(--paper-deep)}.popular-card h3{font:400 clamp(1.4rem,2.2vw,2.1rem)/.98 var(--serif);letter-spacing:-.04em;margin:28px 0 auto}.card-arrow{font:600 .68rem var(--mono);margin-top:24px}.card-arrow span{color:var(--red);margin-left:10px}.topic-list{list-style:none;padding:0;margin:0;border-top:1px solid var(--ink)}.topic-list li a{display:grid;grid-template-columns:1fr 35px;gap:20px;align-items:center;border-bottom:1px solid var(--line);padding:18px 0;transition:padding .2s,background .2s}.topic-list li a:hover{padding-left:14px;background:var(--paper-deep)}.topic-list h3{font:400 clamp(1.8rem,3vw,3.3rem)/.9 var(--serif);letter-spacing:-.05em;margin:2px 0}.topic-list p{margin:5px 0 0;color:var(--muted);font-size:.8rem}.topic-arrow{font-size:1.3rem}.content-status{display:inline-block;padding:4px 7px;background:#d8d1c5;font:600 .58rem var(--mono);text-transform:uppercase}.status-full-investigation{background:#cfe5cb}.status-in-progress{background:#f3d7a4}.next-up{margin-top:35px;padding:20px;border-left:5px solid var(--red);background:var(--paper-deep)}.next-up a{text-decoration:underline;font-weight:700}.home-method{padding:clamp(70px,10vw,135px) clamp(20px,12vw,190px);background:var(--red);color:#fff}.home-method h2{font:400 clamp(2.5rem,5vw,5rem)/.88 var(--serif);letter-spacing:-.06em;margin:0}.home-method p:not(.eyebrow){max-width:480px;line-height:1.55;margin:35px 0;color:#ffeae5}.home-method .action-link{color:#fff;border-bottom:1px solid #fff;padding-bottom:5px}@media(max-width:900px){.popular-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:700px){.homepage-hero{min-height:640px;padding-top:110px}.hero-side-note{left:20px;right:20px;bottom:45px;max-width:none}.popular-grid{grid-template-columns:1fr}.popular-card{min-height:205px}.topic-list li a{grid-template-columns:1fr 20px}}
</style>
