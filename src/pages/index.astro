---
import BaseLayout from '../layouts/BaseLayout.astro';
import { concerns } from '../data/concerns';
import { curatedSearch, popularQuestions } from '../data/search';
const searchPayload = JSON.stringify(curatedSearch).replace(/</g, '\\u003c');
const featured = concerns.filter(item => ['vivienda','inmigracion','empleo','politica','sanidad'].includes(item.slug));
---
<BaseLayout description="Comprueba afirmaciones sobre España con datos públicos, contexto y fuentes originales.">
  <section class="hero claim-hero">
    <p class="eyebrow">Datos, contexto y fuentes originales</p>
    <h1>¿España está<br /><em>realmente fatal?</em></h1>
    <p class="hero-copy">Busca una afirmación, una cifra o un problema. Te mostramos qué sabemos, qué no sabemos y de dónde salen los datos.</p>
    <form class="claim-search" role="search" action="#resultados">
      <label for="claim-query">Escribe o pega una afirmación</label>
      <div><input id="claim-query" name="q" type="search" autocomplete="off" placeholder="“Los inmigrantes viven de ayudas…”" /><button type="submit">Comprobar <span>→</span></button></div>
    </form>
    <div id="resultados" class="search-results" aria-live="polite" hidden></div>
    <noscript><p class="no-script">La búsqueda necesita JavaScript. Puedes usar las preguntas populares o explorar las preocupaciones.</p></noscript>
  </section>

  <section class="popular"><div class="section-title"><p class="eyebrow">Preguntas populares</p><h2>Empieza por una<br /><em>afirmación concreta.</em></h2></div><div class="question-grid">{popularQuestions.map(item => <a href={item.href}><span>{item.topic}</span><h3>{item.question}</h3><p>{item.answer}</p><b>Ver respuesta →</b></a>)}</div></section>

  <section id="preocupaciones" class="concerns"><div class="section-head"><p class="eyebrow">Los asuntos de fondo</p><h2>Explora la<br /><em>evidencia completa.</em></h2><p>Las investigaciones sostienen las respuestas breves. Cada una publica datos, límites, interpretaciones y fuentes.</p></div><ol>{concerns.map(item => <li><a href={`/preocupaciones/${item.slug}`}><span class="rank">{String(item.rank).padStart(2,'0')}</span><div><h3>{item.title}</h3><p>{item.short}</p></div><strong class="list-stat">{item.stat}</strong><span class="arrow">↗</span></a></li>)}</ol></section>

  <section class="featured"><div class="section-title"><p class="eyebrow">Investigaciones destacadas</p><h2>Para entenderlo<br /><em>sin atajos.</em></h2></div><div class="featured-grid">{featured.map(item => <a href={`/preocupaciones/${item.slug}`}><span>{item.short}</span><h3>{item.title}</h3><p>{item.summary}</p><b>Leer investigación →</b></a>)}</div></section>

  <section class="method-callout"><p class="eyebrow">Cómo lo sabemos</p><h2>La respuesta no termina<br /><em>en nuestro veredicto.</em></h2><p>Datos originales → cálculo reproducible → interpretación separada → correcciones públicas. Puedes abrir cada fuente y revisar sus límites.</p><a class="text-link" href="/metodologia">Así trabajamos <span>→</span></a></section>

  <script is:inline type="application/json" id="search-data" set:html={searchPayload}></script>
  <script>
    const form = document.querySelector<HTMLFormElement>('.claim-search');
    const input = document.querySelector<HTMLInputElement>('#claim-query');
    const results = document.querySelector<HTMLElement>('#resultados');
    const data = JSON.parse(document.querySelector('#search-data')?.textContent || '[]');
    const normalise = (value:string) => value.toLocaleLowerCase('es').normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9ñ]+/g,' ').trim();
    const score = (item:any, query:string) => { const q=normalise(query); const haystack=normalise([item.question,item.topic,item.answer,...item.keywords].join(' ')); if(!q)return 0; if(normalise(item.question)===q)return 100; if(haystack.includes(q))return 60; return q.split(' ').filter((word:string)=>word.length>2&&haystack.includes(word)).length; };
    form?.addEventListener('submit', event => { event.preventDefault(); if(!input||!results)return; const ranked=data.map((item:any)=>({...item,score:score(item,input.value)})).filter((item:any)=>item.score>0).sort((a:any,b:any)=>b.score-a.score).slice(0,4); results.hidden=false; results.innerHTML=ranked.length?`<p class="eyebrow">${ranked[0].score>=60?'Respuesta curada':'No hay una respuesta exacta. Esto es lo más relacionado:'}</p>${ranked.map((item:any)=>`<a href="${item.href}"><span>${item.topic}</span><strong>${item.question}</strong><small>${item.answer}</small></a>`).join('')}`:'<p>No tenemos todavía una respuesta curada para esa afirmación. Explora los asuntos de fondo más abajo.</p>'; results.scrollIntoView({behavior:'smooth',block:'nearest'}); });
  </script>
</BaseLayout>
<style>
  .claim-hero{min-height:auto;padding-bottom:95px}.claim-search{max-width:820px;margin-top:36px}.claim-search label{display:block;font:600 .72rem var(--mono);text-transform:uppercase;margin-bottom:9px}.claim-search>div{display:grid;grid-template-columns:1fr auto;border:2px solid var(--ink);background:var(--paper)}.claim-search input{min-width:0;border:0;background:transparent;padding:19px;font:1.05rem var(--sans);outline:none}.claim-search input:focus{box-shadow:inset 0 0 0 3px var(--yellow)}.claim-search button{border:0;background:var(--ink);color:white;padding:0 22px;font:600 .82rem var(--sans);cursor:pointer}.claim-search button span{color:var(--yellow);margin-left:14px}.search-results{max-width:820px;background:#e9e1d4;padding:20px;margin-top:12px}.search-results>a{display:grid;grid-template-columns:100px 1fr;gap:5px 15px;padding:13px 0;border-top:1px solid var(--line)}.search-results span{font:.65rem var(--mono);color:var(--red)}.search-results strong{font:1.2rem var(--serif)}.search-results small{grid-column:2;color:var(--muted)}.popular,.featured{padding:clamp(70px,10vw,130px) clamp(20px,7vw,110px);border-bottom:1px solid var(--line)}.section-title{display:grid;grid-template-columns:1fr 2fr;margin-bottom:50px}.section-title h2{font:clamp(2.7rem,5vw,5rem)/.88 var(--serif);letter-spacing:-.06em;margin:0}.question-grid,.featured-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line)}.question-grid a,.featured-grid a{background:var(--paper);padding:28px;min-height:250px}.question-grid a:hover,.featured-grid a:hover{background:#ede7dc}.question-grid span,.featured-grid span{font:.66rem var(--mono);text-transform:uppercase;color:var(--red)}.question-grid h3,.featured-grid h3{font:2rem/.98 var(--serif);margin:35px 0 14px}.question-grid p,.featured-grid p{color:var(--muted);font-size:.86rem}.question-grid b,.featured-grid b{display:block;margin-top:24px;font-size:.75rem}.featured-grid{grid-template-columns:repeat(5,1fr)}.featured-grid a{min-height:330px}.featured-grid h3{font-size:1.75rem}.concerns li a{grid-template-columns:85px 1fr auto 30px;gap:18px}.list-stat{font:clamp(1.1rem,2vw,1.7rem)/1 var(--serif);color:var(--red);white-space:nowrap}.no-script{font-size:.8rem;color:var(--muted)}
  @media(max-width:900px){.featured-grid{grid-template-columns:1fr 1fr}.featured-grid a:last-child{grid-column:1/-1}}
  @media(max-width:700px){.claim-search>div{grid-template-columns:1fr}.claim-search button{padding:15px}.section-title{grid-template-columns:1fr}.question-grid,.featured-grid{grid-template-columns:1fr}.featured-grid a:last-child{grid-column:auto}.search-results>a{grid-template-columns:1fr}.search-results small{grid-column:1}.concerns li a{grid-template-columns:42px 1fr auto 18px;gap:7px}.list-stat{font-size:1rem}}
</style>
