---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicBadge from '../components/TopicBadge.astro';
import ActionLink from '../components/ActionLink.astro';
import { concerns } from '../data/concerns';
import { popularClaims } from '../data/popularClaims';
import { conversationMvpClaims } from '../data/conversationMvp';
const featuredConcerns = concerns.filter((item) => ['vivienda','inmigracion','empleo','politica','sanidad'].includes(item.slug));
const conversationPayload = JSON.stringify(conversationMvpClaims).replace(/</g, '\\u003c');
const ollamaEndpoint = import.meta.env.PUBLIC_OLLAMA_ENDPOINT || 'http://localhost:11434/api/chat';
const ollamaTextModel = import.meta.env.PUBLIC_OLLAMA_TEXT_MODEL || 'qwen3.6:latest';
const ollamaVisionModel = import.meta.env.PUBLIC_OLLAMA_VISION_MODEL || 'qwen3-vl:8b';
const inferencePayload = JSON.stringify({ ollamaEndpoint, ollamaTextModel, ollamaVisionModel }).replace(/</g, '\\u003c');
---
<BaseLayout description="Comprueba afirmaciones sobre España con datos públicos, contexto y fuentes originales.">
  <section class="homepage-hero">
    <div class="hero-copy-block"><p class="eyebrow">Datos, contexto y fuentes originales</p><h1>El país está fatal.<br /><em>¿Seguro?</em></h1></div>
  </section>
  <section class="conversation-mvp" id="comprobar">
    <div class="conversation-heading"><p class="eyebrow">Una forma rápida de aclararlo</p><h2>¿De qué estáis<br /><em>discutiendo?</em></h2><p>Escríbelo como te lo han contado. No hace falta formularlo perfectamente. Te ayudamos a separar la preocupación real, los datos y lo que todavía no se puede concluir.</p></div>
    <div class="conversation-tool">
      <form class="conversation-form" id="conversation-form" role="search"><label for="conversation-input">Escribe una afirmación</label><div><input id="conversation-input" name="q" type="search" autocomplete="off" placeholder="“Los inmigrantes crean inseguridad…”" /><button type="submit">Aclarar <span aria-hidden="true">→</span></button></div></form>
      <form class="local-media-form" id="local-media-form"><label for="local-media-input">O sube una captura o audio <small>solo en tu dispositivo</small></label><div><input id="local-media-input" type="file" accept="image/*,audio/*" /><button type="submit">Analizar archivo <span aria-hidden="true">↗</span></button></div></form>
      <div class="conversation-examples" aria-label="Afirmaciones populares"><span>Prueba una:</span>{conversationMvpClaims.map((item) => <button type="button" data-example={item.prompt}>{item.prompt}</button>)}</div>
      <div class="conversation-result" id="conversation-result" aria-live="polite"></div>
      <noscript><p class="conversation-noscript">Activa JavaScript para escribir una afirmación. También puedes empezar por <a href="/afirmaciones">las afirmaciones publicadas</a>.</p></noscript>
    </div>
  </section>
  <section id="afirmaciones" class="popular-home"><header class="section-header section-header-split"><div><p class="eyebrow">Preguntas que comprobamos</p><h2>Antes de compartir,<br /><em>mira los datos.</em></h2></div><p class="section-header-description">Este proyecto reúne afirmaciones frecuentes sobre España y las contrasta con datos públicos, contexto y fuentes que puedes consultar.</p></header><div class="popular-grid">{popularClaims.map((item) => <a class="popular-card" href={`/afirmaciones/${item.slug}`}><TopicBadge slug={item.topicSlug} compact /><h3>{item.claim.replace(/[“”]/g,'')}</h3><span class="card-arrow">Comprobar <span aria-hidden="true">→</span></span></a>)}</div><ActionLink href="/afirmaciones" label="Ver todas las afirmaciones" /></section>
  <section id="temas" class="topics-home"><header class="section-header section-header-split"><div><p class="eyebrow">Investigaciones en profundidad</p><h2>Los problemas<br /><em>de fondo.</em></h2></div><p class="section-header-description">Empieza por las investigaciones destacadas o abre el mapa completo de temas publicados y previstos.</p></header><ol class="topic-list">{featuredConcerns.map((item) => <li><a href={`/preocupaciones/${item.slug}`}><div><h3>{item.title}</h3><p>{item.short}</p></div><span class="topic-arrow" aria-hidden="true">↗</span></a></li>)}</ol><p style="margin-top:28px"><ActionLink href="/investigaciones" label={`Ver las ${concerns.length} investigaciones y el mapa completo`} /></p></section>
</BaseLayout>
<script is:inline type="application/json" id="conversation-mvp-data" set:html={conversationPayload}></script>
<script is:inline type="application/json" id="inference-config" set:html={inferencePayload}></script>
<script is:inline>
  const conversationData=JSON.parse(document.querySelector('#conversation-mvp-data')?.textContent||'[]');
  const inferenceConfig=JSON.parse(document.querySelector('#inference-config')?.textContent||'{}');
  const ollamaEndpoint=inferenceConfig.ollamaEndpoint||'http://localhost:11434/api/chat';
  const ollamaTextModel=inferenceConfig.ollamaTextModel||'qwen3.6:latest';
  const ollamaVisionModel=inferenceConfig.ollamaVisionModel||'qwen3-vl:8b';
  const normalise=(value)=>value.toLocaleLowerCase('es').normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9ñ]+/g,' ').trim();
  const form=document.querySelector('#conversation-form');const input=document.querySelector('#conversation-input');const result=document.querySelector('#conversation-result');
  const findClaim=(value)=>{const query=normalise(value);if(!query)return null;const words=query.split(' ').filter((word)=>word.length>2);return conversationData.map((item)=>{const haystack=normalise([item.prompt,...item.aliases].join(' '));const exact=haystack.includes(query)||query.includes(normalise(item.prompt));const score=(exact?100:0)+words.filter((word)=>haystack.includes(word)).length;return {...item,score};}).filter((item)=>item.score>1).sort((a,b)=>b.score-a.score)[0]||null;};
  const render=(claim,query)=>{if(!result)return;if(!claim){result.innerHTML=`<div class="conversation-empty"><strong>Aún no tenemos una respuesta directa para esa formulación.</strong><p>No vamos a inventar una conclusión a partir de datos parecidos. Prueba una de las afirmaciones populares o <a href="/buscar?q=${encodeURIComponent(query)}">explora las respuestas publicadas</a>.</p><button type="button" id="ollama-local" class="local-ai-button">Intentar clasificar con Ollama local <span>↗</span></button><small class="local-ai-note">Solo funciona si Ollama está activo en este dispositivo. El texto se envía a localhost y no a este sitio.</small></div>`;document.querySelector('#ollama-local')?.addEventListener('click',()=>classifyWithOllama(query));return;}result.innerHTML=`<article class="clarification-card"><div class="clarification-top"><span class="eyebrow">La discusión contiene varias preguntas</span><a data-claim-link="${claim.slug}">Ver la afirmación completa →</a></div><h3>${claim.prompt}</h3><div class="proposition-grid">${claim.propositions.map((item,index)=>`<div><small>Parte ${index+1}</small><p>${item}</p></div>`).join('')}</div><div class="clarification-columns"><div><span class="clarification-label">La preocupación real</span><p>${claim.concern}</p></div><div><span class="clarification-label">Lo que apoyan los datos</span><p>${claim.supports}</p></div><div><span class="clarification-label">Lo que no permiten concluir</span><p>${claim.limit}</p></div></div><div class="clarification-highlight"><span class="clarification-label">La pregunta que aclara el debate</span><strong>${claim.question}</strong></div><div class="clarification-reply"><span class="clarification-label">Una respuesta que puedes compartir</span><p>“${claim.reply}”</p><button type="button" data-copy="${claim.reply.replace(/"/g,'&quot;')}">Copiar respuesta</button></div><div class="clarification-footer"><span>${claim.visualLabel}</span><a data-claim-link="${claim.slug}">Fuentes y datos →</a></div></article>`;result.querySelectorAll('[data-claim-link]').forEach((link)=>link.setAttribute('href','/afirmaciones/'+claim.slug));};
  const classifyWithOllama=async(query)=>{const button=document.querySelector('#ollama-local');if(button){button.textContent='Clasificando en este dispositivo…';button.setAttribute('disabled','true');}const allowed=conversationData.map((item)=>({slug:item.slug,prompt:item.prompt}));try{const response=await fetch(ollamaEndpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:ollamaTextModel,stream:false,format:{type:'object',properties:{slug:{type:'string'},reason:{type:'string'}},required:['slug','reason']},messages:[{role:'system',content:'Clasifica el texto en una de las afirmaciones aprobadas. Devuelve JSON exacto. No respondas la afirmación ni inventes hechos. Si ninguna encaja, usa slug none.'},{role:'user',content:JSON.stringify({text:query,allowed})}]})});if(!response.ok)throw new Error(`Ollama respondió ${response.status}`);const data=await response.json();const parsed=JSON.parse(data.message?.content||'{}');const claim=conversationData.find((item)=>item.slug===parsed.slug);if(claim){location.href='/aclarar/'+claim.slug;}else if(result){result.innerHTML='<div class="conversation-empty"><strong>Ollama no encontró una afirmación aprobada que encaje.</strong><p>El sistema no ha generado una respuesta nueva. Añade una investigación al proyecto si esta pregunta merece cobertura.</p></div>';}}catch(error){if(result){const cors=error instanceof TypeError||String(error.message).includes('403');result.innerHTML=`<div class="conversation-empty"><strong>No se pudo conectar con Ollama local.</strong><p>${cors?'Ollama está bloqueando esta web por CORS. Añade <code>https://elpaisestafatal.es</code> a <code>OLLAMA_ORIGINS</code> y reinicia Ollama.':'Comprueba que Ollama esté activo y que el modelo configurado esté instalado.'}</p></div>`;}}};
  const classifyLocalImage=async(file)=>{const reader=new FileReader();reader.onload=async()=>{const base64=String(reader.result||'').split(',')[1];const allowed=conversationData.map((item)=>({slug:item.slug,prompt:item.prompt}));try{const response=await fetch(ollamaEndpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:ollamaVisionModel,stream:false,format:{type:'object',properties:{slug:{type:'string'},reason:{type:'string'}},required:['slug','reason']},messages:[{role:'system',content:'Extrae la afirmación principal de la imagen y clasifícala en una de las opciones aprobadas. Devuelve solo JSON. No inventes hechos. Si no encaja, usa slug none.'},{role:'user',content:JSON.stringify({allowed}),images:[base64]}]})});if(!response.ok)throw new Error(`Ollama respondió ${response.status}`);const data=await response.json();const parsed=JSON.parse(data.message?.content||'{}');const claim=conversationData.find((item)=>item.slug===parsed.slug);if(claim)location.href='/aclarar/'+claim.slug;else if(result)result.innerHTML='<div class="conversation-empty"><strong>No encontramos una afirmación aprobada en esa imagen.</strong><p>No se ha generado una respuesta nueva.</p></div>';}catch(error){if(result){const cors=error instanceof TypeError||String(error.message).includes('403');result.innerHTML=`<div class="conversation-empty"><strong>No se pudo analizar la captura.</strong><p>${cors?'Ollama está bloqueando esta web por CORS. Añade <code>https://elpaisestafatal.es</code> a <code>OLLAMA_ORIGINS</code> y reinicia Ollama.':'Comprueba que Ollama esté activo y que el modelo configurado esté instalado.'}</p></div>`;}}};reader.readAsDataURL(file);};
  document.querySelector('#local-media-form')?.addEventListener('submit',(event)=>{event.preventDefault();const file=document.querySelector('#local-media-input')?.files?.[0];if(!file||!result)return;if(file.type.startsWith('audio/')){result.innerHTML='<div class="conversation-empty"><strong>El audio todavía no está transcrito.</strong><p>Usa <code>npm run clarify:local -- --audio /ruta/al/audio</code> cuando tengas un motor local de transcripción instalado.</p></div>';return;}result.innerHTML='<div class="conversation-empty"><strong>Analizando la imagen en este dispositivo…</strong></div>';classifyLocalImage(file);});
  form?.addEventListener('submit',(event)=>{event.preventDefault();const query=input?.value.trim()||'';const claim=findClaim(query);if(claim){location.href='/aclarar/'+claim.slug;}else{render(null,query);result?.scrollIntoView({behavior:'smooth',block:'start'});}});document.querySelectorAll('[data-example]').forEach((button)=>button.addEventListener('click',()=>{if(input){input.value=button.dataset.example||'';form?.requestSubmit();}}));document.addEventListener('click',async(event)=>{const button=event.target.closest('[data-copy]');if(!button)return;try{await navigator.clipboard.writeText(button.dataset.copy||'');button.textContent='Respuesta copiada';}catch{button.textContent='Selecciona el texto para copiarlo';}});
</script>
<style>
  .homepage-hero{min-height:600px;padding:clamp(90px,14vw,180px) clamp(20px,12vw,190px) 90px;position:relative;border-bottom:1px solid var(--line)}.homepage-hero h1{font:400 clamp(3.8rem,8.5vw,8.3rem)/.82 var(--serif);letter-spacing:-.07em;margin:0;max-width:1000px}.homepage-hero h1 em{font-weight:400}.hero-copy-block{max-width:900px}.hero-search{max-width:760px;margin-top:42px}.hero-search label{display:block;font:600 .68rem var(--mono);text-transform:uppercase;margin-bottom:8px}.hero-search>div{display:grid;grid-template-columns:1fr auto;border:2px solid var(--ink);background:var(--paper)}.hero-search input{min-width:0;border:0;background:transparent;padding:16px;outline:0}.hero-search button{border:0;background:var(--ink);color:var(--paper);padding:0 20px;font-weight:700;cursor:pointer}.hero-search button span{color:var(--yellow);margin-left:12px}.conversation-mvp{display:grid;grid-template-columns:.8fr 1.2fr;gap:70px;padding:clamp(65px,9vw,120px) clamp(20px,8vw,120px);border-bottom:1px solid var(--line);background:var(--paper-deep)}.conversation-heading h2{font:400 clamp(2.8rem,5vw,5.5rem)/.88 var(--serif);letter-spacing:-.06em;margin:0 0 25px}.conversation-heading>p:last-child{max-width:380px;font:1.15rem/1.35 var(--serif)}.conversation-form label{display:block;font:600 .68rem var(--mono);text-transform:uppercase;margin-bottom:8px}.conversation-form>div{display:grid;grid-template-columns:1fr auto;border:2px solid var(--ink);background:var(--paper)}.conversation-form input{min-width:0;border:0;background:transparent;padding:17px;outline:0;font:1rem var(--sans)}.conversation-form button{border:0;background:var(--ink);color:var(--paper);padding:0 20px;font-weight:700;cursor:pointer}.conversation-form button span{color:var(--yellow);margin-left:10px}.conversation-examples{display:flex;flex-wrap:wrap;gap:8px;margin:18px 0 28px;font-size:.78rem;align-items:center}.conversation-examples>span{font:600 .62rem var(--mono);text-transform:uppercase;color:var(--muted)}.conversation-examples button{border:1px solid var(--line);background:var(--paper);padding:8px 10px;text-align:left;cursor:pointer}.conversation-examples button:hover{border-color:var(--ink)}.conversation-result{scroll-margin-top:20px}.conversation-empty,.clarification-card{border-top:2px solid var(--ink);padding-top:20px}.conversation-empty strong{font:1.5rem/1 var(--serif)}.conversation-empty p{line-height:1.5;max-width:600px}.clarification-top,.clarification-footer{display:flex;justify-content:space-between;gap:15px;align-items:center}.clarification-top a,.clarification-footer a{font:600 .68rem var(--mono);color:var(--red)}.clarification-card h3{font:400 clamp(2rem,3.5vw,3.4rem)/.95 var(--serif);letter-spacing:-.05em;margin:22px 0}.proposition-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin:0 0 24px}.proposition-grid>div{background:var(--paper);padding:16px}.proposition-grid small{font:600 .62rem var(--mono);text-transform:uppercase;color:var(--red)}.proposition-grid p{margin:10px 0 0;font-size:.92rem;line-height:1.35}.clarification-columns{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}.clarification-columns p{line-height:1.45}.clarification-label{display:block;font:600 .62rem var(--mono);text-transform:uppercase;color:var(--red)}.clarification-highlight{padding:20px;background:var(--yellow);margin:12px 0 18px}.clarification-highlight strong{display:block;font:1.3rem/1.1 var(--serif);margin-top:8px}.clarification-reply{border:1px solid var(--line);padding:18px}.clarification-reply p{font:1.15rem/1.35 var(--serif)}.clarification-reply button{border:1px solid var(--ink);background:transparent;padding:9px 12px;font:600 .65rem var(--mono);cursor:pointer}.clarification-footer{border-top:1px solid var(--line);margin-top:18px;padding-top:15px;font:600 .65rem var(--mono)}.conversation-noscript{border-top:1px solid var(--line);padding-top:18px}.popular-home,.topics-home{padding:clamp(70px,10vw,130px) clamp(20px,7vw,110px);border-bottom:1px solid var(--line)}.popular-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);margin-bottom:35px}.popular-card{background:var(--paper);min-height:250px;padding:25px;display:flex;flex-direction:column;align-items:flex-start;transition:background .2s}.popular-card:hover{background:var(--paper-deep)}.popular-card h3{font:400 clamp(1.4rem,2.2vw,2.1rem)/.98 var(--serif);letter-spacing:-.04em;margin:28px 0 auto}.card-arrow{font:600 .68rem var(--mono);margin-top:24px}.card-arrow span{color:var(--red);margin-left:10px}.home-intro{display:grid;grid-template-columns:1.2fr .8fr;gap:70px;align-items:start;padding:clamp(70px,10vw,130px) clamp(20px,12vw,190px);background:var(--paper-deep);border-bottom:1px solid var(--line)}.home-intro h2{font:400 clamp(2.7rem,5vw,5rem)/.88 var(--serif);letter-spacing:-.065em;margin:0}.home-intro>div:last-child>p{max-width:420px;font:1.2rem/1.35 var(--serif);margin:5px 0 35px}.topic-count{display:flex;align-items:baseline;gap:14px;font:400 4.5rem/.8 var(--serif);color:var(--red)}.topic-count span{font:600 .68rem/1.3 var(--mono);color:var(--ink);text-transform:uppercase}.topic-list{list-style:none;padding:0;margin:0;border-top:1px solid var(--ink)}.topic-list li a{display:grid;grid-template-columns:1fr 35px;gap:20px;align-items:center;border-bottom:1px solid var(--line);padding:18px 0;transition:padding .2s,background .2s}.topic-list li a:hover{padding-left:14px;background:var(--paper-deep)}.topic-list h3{font:400 clamp(1.8rem,3vw,3.3rem)/.9 var(--serif);letter-spacing:-.05em;margin:2px 0}.topic-list p{margin:5px 0 0;color:var(--muted);font-size:.8rem}.topic-arrow{font-size:1.3rem}@media(max-width:900px){.popular-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:700px){.homepage-hero{min-height:570px;padding-top:105px}.hero-search>div,.conversation-form>div{grid-template-columns:1fr}.hero-search button,.conversation-form button{padding:14px}.conversation-mvp{grid-template-columns:1fr;gap:30px;padding-top:65px;padding-bottom:65px}.proposition-grid,.clarification-columns{grid-template-columns:1fr}.popular-grid{grid-template-columns:1fr}.popular-card{min-height:205px}.home-intro{grid-template-columns:1fr;gap:30px;padding-top:65px;padding-bottom:65px}.home-intro>div:last-child>p{margin-top:0}.topic-count{font-size:3.8rem}.topic-list li a{grid-template-columns:1fr 20px}}
</style>
<style>
  .local-ai-button{display:block;margin-top:20px;border:1px solid var(--ink);background:var(--ink);color:var(--paper);padding:12px 16px;font:600 .68rem var(--mono);cursor:pointer}.local-ai-button span{color:var(--yellow);margin-left:8px}.local-ai-button:disabled{opacity:.65;cursor:wait}.local-ai-note{display:block;color:var(--muted);font-size:.72rem;line-height:1.4;margin-top:10px}.local-media-form{margin-top:14px}.local-media-form label{display:block;font:600 .62rem var(--mono);text-transform:uppercase;color:var(--muted);margin-bottom:7px}.local-media-form label small{font-weight:400;text-transform:none}.local-media-form>div{display:grid;grid-template-columns:1fr auto;gap:8px}.local-media-form input{min-width:0;border:1px dashed var(--line);padding:10px;background:var(--paper);font-size:.75rem}.local-media-form button{border:1px solid var(--ink);background:transparent;padding:0 13px;font:600 .62rem var(--mono);cursor:pointer}@media(max-width:700px){.local-media-form>div{grid-template-columns:1fr}.local-media-form button{padding:12px}}
</style>
