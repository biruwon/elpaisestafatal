---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicBadge from '../components/TopicBadge.astro';
import ActionLink from '../components/ActionLink.astro';
import { concerns } from '../data/concerns';
import { popularClaims } from '../data/popularClaims';
---
<BaseLayout description="Comprueba afirmaciones sobre España con datos públicos, contexto y fuentes originales." hideSecondaryLinks>
  <section class="homepage-hero">
    <div class="hero-copy-block"><p class="eyebrow">Datos, contexto y fuentes originales</p><h1>El país está fatal.<br /><em>¿Seguro?</em></h1></div>
  </section>
  <section id="afirmaciones" class="popular-home"><header class="section-header section-header-split"><div><p class="eyebrow">Afirmaciones populares</p><h2>Empieza por una<br /><em>pregunta concreta.</em></h2></div><p class="section-header-description">Preguntas frecuentes, respuestas breves y enlaces a la evidencia. No son un ranking ni una encuesta de popularidad.</p></header><div class="popular-grid">{popularClaims.map((item) => <a class="popular-card" href={`/afirmaciones/${item.slug}`}><TopicBadge slug={item.topicSlug} compact /><h3>{item.claim.replace(/[“”]/g,'')}</h3><span class="card-arrow">Comprobar <span aria-hidden="true">→</span></span></a>)}</div><ActionLink href="/afirmaciones" label="Ver todas las afirmaciones" /></section>
  <section class="home-intro"><div><p class="eyebrow">Una pregunta antes de compartir</p><h2>Comprueba qué se sabe,<br /><em>qué falta y qué no.</em></h2></div><div><form class="hero-search home-claim-search" role="search" action="/buscar" method="get"><label for="home-query">Escribe o pega una afirmación</label><div><input id="home-query" name="q" type="search" autocomplete="off" placeholder="“Los inmigrantes viven de ayudas…”" /><button type="submit">Comprobar <span>→</span></button></div></form><p>Una respuesta útil separa el hecho, el contexto y el límite de cada dato. Aquí no generamos respuestas nuevas: ordenamos evidencia pública para que puedas revisarla.</p><strong class="topic-count">{concerns.length}<span>temas investigados<br />con fuentes abiertas</span></strong></div></section>
  <section id="temas" class="topics-home"><header class="section-header section-header-split"><div><p class="eyebrow">Temas</p><h2>Los problemas<br /><em>de fondo.</em></h2></div><p class="section-header-description">Explora los temas y sus investigaciones. La profundidad editorial se explica dentro de cada página.</p></header><ol class="topic-list">{concerns.map((item) => <li><a href={`/preocupaciones/${item.slug}`}><div><h3>{item.title}</h3><p>{item.short}</p></div><span class="topic-arrow" aria-hidden="true">↗</span></a></li>)}</ol></section>
</BaseLayout>
<style>
  .homepage-hero{min-height:600px;padding:clamp(90px,14vw,180px) clamp(20px,12vw,190px) 90px;position:relative;border-bottom:1px solid var(--line)}.homepage-hero h1{font:400 clamp(3.8rem,8.5vw,8.3rem)/.82 var(--serif);letter-spacing:-.07em;margin:0;max-width:1000px}.homepage-hero h1 em{font-weight:400}.hero-copy-block{max-width:900px}.hero-search{max-width:760px;margin-top:42px}.hero-search label{display:block;font:600 .68rem var(--mono);text-transform:uppercase;margin-bottom:8px}.hero-search>div{display:grid;grid-template-columns:1fr auto;border:2px solid var(--ink);background:var(--paper)}.hero-search input{min-width:0;border:0;background:transparent;padding:16px;outline:0}.hero-search button{border:0;background:var(--ink);color:var(--paper);padding:0 20px;font-weight:700;cursor:pointer}.hero-search button span{color:var(--yellow);margin-left:12px}.popular-home,.topics-home{padding:clamp(70px,10vw,130px) clamp(20px,7vw,110px);border-bottom:1px solid var(--line)}.popular-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);margin-bottom:35px}.popular-card{background:var(--paper);min-height:250px;padding:25px;display:flex;flex-direction:column;align-items:flex-start;transition:background .2s}.popular-card:hover{background:var(--paper-deep)}.popular-card h3{font:400 clamp(1.4rem,2.2vw,2.1rem)/.98 var(--serif);letter-spacing:-.04em;margin:28px 0 auto}.card-arrow{font:600 .68rem var(--mono);margin-top:24px}.card-arrow span{color:var(--red);margin-left:10px}.home-intro{display:grid;grid-template-columns:1.2fr .8fr;gap:70px;align-items:start;padding:clamp(70px,10vw,130px) clamp(20px,12vw,190px);background:var(--paper-deep);border-bottom:1px solid var(--line)}.home-intro h2{font:400 clamp(2.7rem,5vw,5rem)/.88 var(--serif);letter-spacing:-.065em;margin:0}.home-intro>div:last-child>p{max-width:420px;font:1.2rem/1.35 var(--serif);margin:5px 0 35px}.topic-count{display:flex;align-items:baseline;gap:14px;font:400 4.5rem/.8 var(--serif);color:var(--red)}.topic-count span{font:600 .68rem/1.3 var(--mono);color:var(--ink);text-transform:uppercase}.topic-list{list-style:none;padding:0;margin:0;border-top:1px solid var(--ink)}.topic-list li a{display:grid;grid-template-columns:1fr 35px;gap:20px;align-items:center;border-bottom:1px solid var(--line);padding:18px 0;transition:padding .2s,background .2s}.topic-list li a:hover{padding-left:14px;background:var(--paper-deep)}.topic-list h3{font:400 clamp(1.8rem,3vw,3.3rem)/.9 var(--serif);letter-spacing:-.05em;margin:2px 0}.topic-list p{margin:5px 0 0;color:var(--muted);font-size:.8rem}.topic-arrow{font-size:1.3rem}@media(max-width:900px){.popular-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:700px){.homepage-hero{min-height:570px;padding-top:105px}.hero-search>div{grid-template-columns:1fr}.hero-search button{padding:14px}.popular-grid{grid-template-columns:1fr}.popular-card{min-height:205px}.home-intro{grid-template-columns:1fr;gap:30px;padding-top:65px;padding-bottom:65px}.home-intro>div:last-child>p{margin-top:0}.topic-count{font-size:3.8rem}.topic-list li a{grid-template-columns:1fr 20px}}
</style>
