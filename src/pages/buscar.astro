---
import BaseLayout from '../layouts/BaseLayout.astro';
import { curatedSearch } from '../data/search';
import { concerns } from '../data/concerns';
const payload = JSON.stringify({ claims: curatedSearch, topics: concerns.map((item) => ({ title: item.title, short: item.short, href: `/preocupaciones/${item.slug}`, keywords: [item.title, item.short, item.question] })) }).replace(/</g, '\\u003c');
---
<BaseLayout title="Buscar — El país está fatal" description="Busca afirmaciones y temas investigados sobre España.">
  <article class="prose search-page">
    <p class="eyebrow">Búsqueda curada</p>
    <h1>Busca una pregunta<br /><em>comprobable.</em></h1>
    <p class="lead">Encontrarás respuestas ya publicadas o el tema más cercano. No inventamos respuestas para consultas nuevas.</p>
    <form class="site-search" role="search"><label for="site-query">Afirmación o tema</label><div><input id="site-query" type="search" autocomplete="off" placeholder="“La vivienda va a bajar…”" /><button>Buscar <span>→</span></button></div></form>
    <div id="search-output" class="search-output" aria-live="polite"><p class="quiet-note">Escribe para ver resultados.</p></div>
  </article>
  <script is:inline type="application/json" id="search-page-data" set:html={payload}></script>
  <script>
    const form=document.querySelector<HTMLFormElement>('.site-search');const input=document.querySelector<HTMLInputElement>('#site-query');const output=document.querySelector<HTMLElement>('#search-output');const data=JSON.parse(document.querySelector('#search-page-data')?.textContent||'{}');
    const normalise=(v:string)=>v.toLocaleLowerCase('es').normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9ñ]+/g,' ').trim();
    const render=()=>{if(!output||!input)return;const q=normalise(input.value);if(!q){output.innerHTML='<p class="quiet-note">Escribe para ver resultados.</p>';return;}const words=q.split(' ').filter((word:string)=>word.length>2);const groups=[...(data.claims||[]),...(data.topics||[])].map((item:any)=>({...item,score:normalise(item.question||item.title)===q?100:words.filter((word:string)=>normalise([item.question,item.title,item.topic,item.short,...(item.keywords||[])].join(' ')).includes(word)).length})).filter((item:any)=>item.score>0).sort((a:any,b:any)=>b.score-a.score).slice(0,8);output.innerHTML=groups.length?groups.map((item:any)=>`<a href="${item.href}"><span>${item.question?'Afirmación':'Tema'}</span><strong>${item.question||item.title}</strong><small>${item.answer||item.short}</small></a>`).join(''):'<p class="quiet-note">No tenemos una respuesta curada para esa consulta. Prueba con otra formulación o explora los temas.</p>';};
    const initialQuery=new URLSearchParams(location.search).get('q')||'';if(input&&initialQuery){input.value=initialQuery;render();}form?.addEventListener('submit',(event)=>{event.preventDefault();render();});input?.addEventListener('input',render);
  </script>
</BaseLayout>
<style>
  .search-page{max-width:980px}.site-search{margin:45px 0;max-width:760px}.site-search label{display:block;font:600 .68rem var(--mono);text-transform:uppercase;margin-bottom:8px}.site-search>div{display:grid;grid-template-columns:1fr auto;border:2px solid var(--ink)}.site-search input{min-width:0;border:0;background:transparent;padding:17px;outline:0}.site-search button{border:0;background:var(--ink);color:var(--paper);padding:0 20px;font-weight:700;cursor:pointer}.site-search button span{color:var(--yellow);margin-left:12px}.search-output{border-top:1px solid var(--ink)}.search-output>a{display:grid;grid-template-columns:100px 1fr;gap:7px 16px;padding:20px 0;border-bottom:1px solid var(--line);line-height:1.35}.search-output span{font:600 .62rem var(--mono);color:var(--red);text-transform:uppercase}.search-output strong{display:block;font:1.35rem/1.05 var(--serif)}.search-output small{display:block;grid-column:2;color:var(--muted);line-height:1.45;margin-top:2px}@media(max-width:600px){.site-search>div{grid-template-columns:1fr}.site-search button{padding:14px}.search-output>a{grid-template-columns:1fr;gap:6px}.search-output small{grid-column:1}}
</style>
