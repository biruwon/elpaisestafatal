---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { concerns, getConcern } from '../../data/concerns';
import { epistemicLabels, resolveEpistemic, strengthLabels } from '../../data/epistemic';
import { evidenceCauses } from '../../data/evidenceCauses';
import { concernSources, editorialMetadata } from '../../data/provenance';
import { getRegionSeries, regions } from '../../data/regions';
export function getStaticPaths() { return concerns.map((concern) => ({ params: { slug: concern.slug } })); }
const concern = getConcern(Astro.params.slug!);
if (!concern) return Astro.redirect('/');
const pageSources = concernSources(concern);
const statusLabels = {'full-investigation':'Investigación completa','data-briefing':'Informe de datos','in-progress':'En preparación'} as const;
const regional = getRegionSeries(concern.slug);
const regionalPayload = regional ? JSON.stringify(regional).replace(/</g,'\\u003c') : '';
---
<BaseLayout title={`${concern.title} — El país está fatal`} description={concern.summary}>
  <article class="brief"><a class="back" href="/#preocupaciones">← Volver a las {concerns.length} preocupaciones</a><header class="brief-head"><p class="eyebrow">Investigación temática</p><h1>{concern.title}</h1><p>{concern.summary}</p><p class="survey-badge"><b>{concern.stat}</b> {concern.statLabel} · <a href="/#comparison-title">comparar con el mismo método →</a></p><div class="page-meta"><span>Estado: {statusLabels[concern.status]}</span><span>Revisado: {concern.lastReviewed}</span><span>{editorialMetadata.editorialRole}</span><span>{editorialMetadata.dataReviewRole}</span><span>{pageSources.length} fuentes</span><span>{editorialMetadata.calculationMethod}</span></div></header>
  <nav class="reading-modes" aria-label="Niveles de lectura"><a href="#respuesta">Entenderlo en 60 segundos</a><a href="#evidencia">Ver la evidencia</a>{concern.investigation && <a href="#investigacion">Leer la investigación completa</a>}</nav>
  <section id="respuesta" class="quick-answer"><div class="quick-head"><div><span class="epistemic epistemic-interpretation">{epistemicLabels.interpretation}</span><p class="eyebrow">Respuesta en 60 segundos</p><h2>{concern.quickAnswer.sentence}</h2></div><span class={`trend trend-${concern.quickAnswer.trend}`}>{({improving:'Mejora',worsening:'Empeora',mixed:'Mixto',uncertain:'Incierto'} as const)[concern.quickAnswer.trend]}</span></div><div class="quick-facts">{concern.quickAnswer.facts.map(fact => <div><span class="epistemic epistemic-measured-fact">{epistemicLabels['measured-fact']}</span><strong>{fact.value}</strong><span>{fact.label}</span></div>)}</div><div class="truth-grid"><article><span class="epistemic epistemic-measured-fact">{epistemicLabels['measured-fact']}</span><p class="eyebrow">Qué es cierto</p><ul>{concern.quickAnswer.truePoints.map(item => <li>{item}</li>)}</ul></article><article><span class="epistemic epistemic-disputed-interpretation">{epistemicLabels['disputed-interpretation']}</span><p class="eyebrow">Qué resulta engañoso</p><ul>{concern.quickAnswer.misleadingPoints.map(item => <li>{item}</li>)}</ul></article><article><span class="epistemic epistemic-insufficient-evidence">{epistemicLabels['insufficient-evidence']}</span><p class="eyebrow">Qué no sabemos bien</p><ul>{concern.quickAnswer.unknownPoints.map(item => <li>{item}</li>)}</ul></article></div><div class="cause-table"><p class="eyebrow">Fuerza de las principales explicaciones</p>{evidenceCauses[concern.slug].map(cause=><div><strong>{cause.explanation}</strong><span class={`strength strength-${cause.strength}`}>{strengthLabels[cause.strength]}</span><small>{cause.basis}</small></div>)}</div><aside><span class="epistemic epistemic-insufficient-evidence">{epistemicLabels['insufficient-evidence']}</span><p class="eyebrow">Qué podría cambiar esta conclusión</p><p>{concern.quickAnswer.evidenceCouldChange}</p></aside></section>
  <section class="brief-grid"><div><p class="eyebrow">La pregunta</p><h2>{concern.question}</h2><p>{concern.context}</p></div><aside><p class="eyebrow">Límite importante</p><p>{concern.limits}</p></aside></section>
  <span id="evidencia" class="anchor"></span><span id="investigacion" class="anchor"></span>
  <section class="evidence"><p class="eyebrow">{concern.dossier.eyebrow}</p><h2>{concern.dossier.heading}</h2><p>{concern.dossier.intro}</p><div class="metrics">{concern.dossier.metrics.map(metric => <div><strong>{metric.value}</strong><span>{metric.label}</span></div>)}</div><div class="chart"><div class="chart-title"><span>{concern.dossier.series.label}</span><small>{concern.dossier.series.unit}</small></div><div class="bars">{concern.dossier.series.values.map((value,index) => <div><i style={`height:${Math.min(100,Math.abs(value)/Math.max(...concern.dossier.series.values.map(Math.abs))*100)}%`}></i><b>{value}</b><span>{concern.dossier.series.labels[index]}</span></div>)}</div></div><a class="data-source" href={concern.dossier.source.url} target="_blank" rel="noreferrer">Datos: {concern.dossier.source.publisher} · {concern.dossier.source.date} ↗</a><p class="evidence-limit">{concern.dossier.limits}</p></section>
  {regional && <section class="regional" aria-labelledby="regional-title"><div><p class="eyebrow">Comparación autonómica</p><h2 id="regional-title">España frente a tu comunidad</h2><p>{regional.title} · {regional.period}</p></div><label for="region-select">Comunidad autónoma<select id="region-select"><option value="">Selecciona una comunidad</option>{regions.map(region=><option value={region}>{region}</option>)}</select></label><div class="region-values"><article><span>España</span><strong>{regional.national.toLocaleString('es-ES')} {regional.unit}</strong></article><article><span id="region-name">Comunidad</span><strong id="region-value">—</strong></article></div><p id="region-unavailable" hidden>El dato no está disponible con una definición directamente comparable. No se sustituye por otra fuente.</p><p class="evidence-limit">{regional.caveat}</p><a class="data-source" href={regional.source.url} target="_blank" rel="noreferrer">Fuente: {regional.source.label} · {regional.period} ↗</a><script is:inline type="application/json" id="regional-data" set:html={regionalPayload}></script></section>}
  {concern.investigation && <div class="investigation"><header class="investigation-head"><span class="epistemic epistemic-interpretation">{epistemicLabels.interpretation}</span><p class="eyebrow">{concern.investigation.kicker}</p><h2>{concern.investigation.title}</h2><p>{concern.investigation.standfirst}</p><blockquote>{concern.investigation.finding}</blockquote></header><nav class="chapter-index" aria-label="Índice de la investigación">{concern.investigation.sections.map(section => <a href={`#${section.id}`}><span>{section.number}</span>{section.title}</a>)}</nav>{concern.investigation.sections.map(section => { const chartMax = section.chart ? Math.max(...section.chart.values.map(Math.abs)) : 1; return <section class="chapter" id={section.id}><div class="chapter-number">{section.number}</div><div class="chapter-body"><span class={`epistemic epistemic-${resolveEpistemic(section)}`}>{epistemicLabels[resolveEpistemic(section)]}</span><p class="eyebrow">Capítulo {section.number}</p><h2>{section.title}</h2><p class="chapter-intro">{section.intro}</p>{section.paragraphs.map(paragraph => <p>{paragraph}</p>)}{section.metrics && <div class="chapter-metrics">{section.metrics.map(metric => <div><span class="epistemic epistemic-measured-fact">{epistemicLabels["measured-fact"]}</span><strong>{metric.value}</strong><span>{metric.label}</span></div>)}</div>}{section.chart && <figure class="chapter-chart"><figcaption><b>{section.chart.title}</b><span>{section.chart.unit}</span></figcaption><div>{section.chart.values.map((value,index) => <p><span>{section.chart!.labels[index]}</span><i><b style={`width:${Math.max(3,Math.abs(value)/chartMax*100)}%`}></b></i><strong>{String(value).replace('.',',')}</strong></p>)}</div><small>Fuente: <a href={section.chart.source.url} target="_blank" rel="noreferrer">{section.chart.source.publisher} ↗</a></small></figure>}{section.bullets && <ul>{section.bullets.map(item => <li>{item}</li>)}</ul>}{section.verdict && <blockquote>{section.verdict}</blockquote>}{section.source && <a class="chapter-source" href={section.source.url} target="_blank" rel="noreferrer">Fuente principal: {section.source.publisher} · {section.source.date} ↗</a>}</div></section>; })}</div>}
  {concern.video && <section class="video-card" data-video-id={concern.video.videoId}><div><p class="eyebrow">Vídeo · selección provisional</p><h2>{concern.video.title}</h2><p>{concern.video.publisher}</p><p class="video-note">{concern.video.note} <a href={concern.video.url} target="_blank" rel="noreferrer">Ver en YouTube ↗</a></p><button type="button" class="video-load">Cargar vídeo externo <span>▶</span></button></div><div class="play" aria-hidden="true">▶</div></section>}
  <section class="source-section"><div><p class="eyebrow">Comprueba las fuentes</p><h2>De dónde sale<br /><em>esta ficha.</em></h2></div><ol>{concern.sources.map((source, index) => <li><span>{String(index + 1).padStart(2,'0')}</span><a href={source.url} target="_blank" rel="noreferrer"><strong>{source.label}</strong><small>{source.publisher} · {source.date}</small></a><i>↗</i></li>)}</ol></section>
  <nav class="brief-nav"><a href={`/preocupaciones/${concerns[Math.max(0, concern.rank - 2)].slug}`}>← Anterior</a><a href="/#preocupaciones">Ver las {concerns.length}</a><a href={`/preocupaciones/${concerns[Math.min(concerns.length - 1, concern.rank)].slug}`}>Siguiente →</a></nav></article>
  <script>const regionalDataElement=document.querySelector('#regional-data');const regionalData=regionalDataElement?JSON.parse(regionalDataElement.textContent||'{}'):null;const regionSelect=document.querySelector<HTMLSelectElement>('#region-select');const regionName=document.querySelector<HTMLElement>('#region-name');const regionValue=document.querySelector<HTMLElement>('#region-value');const regionUnavailable=document.querySelector<HTMLElement>('#region-unavailable');const showRegion=(name:string)=>{if(!regionalData||!regionName||!regionValue||!regionUnavailable)return;const row=regionalData.values.find((item:{region:string})=>item.region===name);regionName.textContent=name||'Comunidad';regionUnavailable.hidden=!name||row?.value!==null;regionValue.textContent=!name?'—':row?.value===null?'No disponible':`${row.value.toLocaleString('es-ES')} ${regionalData.unit}`;};if(regionSelect){const saved=localStorage.getItem('selected-autonomous-community')||'';if([...regionSelect.options].some(option=>option.value===saved)){regionSelect.value=saved;showRegion(saved);}regionSelect.addEventListener('change',()=>{const value=regionSelect.value;if(value)localStorage.setItem('selected-autonomous-community',value);else localStorage.removeItem('selected-autonomous-community');showRegion(value);});}document.querySelectorAll<HTMLElement>('.video-card').forEach((card) => { card.querySelector('.video-load')?.addEventListener('click', () => { const id = card.dataset.videoId; if (!id) return; card.style.cssText = 'display:block;padding:0;aspect-ratio:16/9'; card.innerHTML = `<iframe title="Vídeo de YouTube" src="https://www.youtube-nocookie.com/embed/${id}?autoplay=1" loading="lazy" style="width:100%;height:100%;border:0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>`; }); });</script>
</BaseLayout>
<style>.regional{padding:70px 0;border-bottom:1px solid var(--line)}.regional>div:first-child{max-width:750px}.regional h2{font:clamp(2.3rem,5vw,5rem)/.9 var(--serif);letter-spacing:-.06em;margin:0 0 12px}.regional label{display:block;margin:30px 0 15px;font:600 .65rem var(--mono);text-transform:uppercase}.regional select{display:block;width:min(100%,480px);margin-top:8px;padding:13px;border:1px solid var(--ink);background:var(--paper);font:1rem var(--sans)}.region-values{display:grid!important;grid-template-columns:1fr 1fr;max-width:720px;border:1px solid var(--ink)}.region-values article{padding:22px}.region-values article+article{border-left:1px solid var(--line)}.region-values span,.region-values strong{display:block}.region-values span{font:.62rem var(--mono);text-transform:uppercase}.region-values strong{font:2rem var(--serif);margin-top:8px}#region-unavailable{max-width:720px;padding:12px;background:#f3d7a4;font-size:.8rem}@media(max-width:700px){.region-values{grid-template-columns:1fr}.region-values article+article{border-left:0;border-top:1px solid var(--line)}}.page-meta{display:flex;flex-wrap:wrap;gap:6px 14px;margin-top:18px;padding-top:14px;border-top:1px solid var(--line);font:.58rem/1.4 var(--mono);color:var(--muted)}.epistemic{display:inline-block;padding:4px 7px;margin:0 0 7px;background:#d9d3c8;font:600 .57rem var(--mono);letter-spacing:.03em;text-transform:uppercase}.epistemic-measured-fact{background:#cfe5cb}.epistemic-project-calculation{background:#cfe0ec}.epistemic-disputed-interpretation{background:#f3d7a4}.epistemic-policy-proposal{background:#ddd0eb}.epistemic-insufficient-evidence{background:#e4bdb6}.cause-table{margin:30px 0;border-top:1px solid var(--ink)}.cause-table>div{display:grid;grid-template-columns:1fr 90px 1fr;gap:15px;padding:15px 0;border-bottom:1px solid var(--line)}.cause-table small{color:var(--muted)}.strength{font:600 .62rem var(--mono);text-transform:uppercase}.strength-high{color:#27623a}.strength-low,.strength-disputed{color:var(--red)}@media(max-width:700px){.cause-table>div{grid-template-columns:1fr}.cause-table small{grid-column:1}}.survey-badge{display:inline-flex;gap:7px;align-items:center;margin:30px 0 0!important;padding:8px 10px;background:#e9e1d4;font:.68rem/1.2 var(--mono)!important;color:var(--muted)}.survey-badge b{color:var(--red)}.survey-badge a{text-decoration:underline}.evidence{padding:80px 0;border-bottom:1px solid var(--line)}.evidence h2,.investigation-head h2{font:clamp(2.4rem,5vw,5.6rem)/.88 var(--serif);letter-spacing:-.065em;margin:0 0 20px}.evidence>p{max-width:700px;font:1.25rem/1.35 var(--serif)}.metrics{display:grid;grid-template-columns:repeat(3,1fr);margin:42px 0 30px;border-top:1px solid var(--ink)}.metrics div{padding:18px;border-right:1px solid var(--line)}.metrics strong{display:block;font:clamp(1.8rem,3.5vw,3.4rem)/.9 var(--serif);letter-spacing:-.06em}.metrics span{font-size:.75rem;color:var(--muted)}.chart{background:#e9e1d4;padding:24px}.chart-title{display:flex;justify-content:space-between;font:600 .75rem var(--mono);text-transform:uppercase}.bars{height:180px;display:flex;align-items:end;gap:10px;margin-top:24px}.bars div{height:100%;flex:1;display:flex;flex-direction:column;justify-content:end;align-items:center;gap:5px}.bars i{display:block;width:100%;background:var(--red)}.bars b{font:.68rem var(--mono)}.bars span{font-size:.6rem;color:var(--muted)}.data-source{display:inline-block;margin-top:12px;font-size:.75rem;text-decoration:underline}.evidence-limit{font:italic .9rem/1.45 var(--sans)!important;color:var(--muted);margin-top:16px}.investigation{padding-top:100px}.investigation-head{max-width:920px;margin-bottom:65px}.investigation-head>p{font:clamp(1.2rem,2vw,1.65rem)/1.4 var(--serif);max-width:760px}.investigation blockquote,.chapter blockquote{margin:32px 0;padding:22px 26px;border-left:5px solid var(--red);background:#e9e1d4;font:1.25rem/1.35 var(--serif)}.chapter-index{display:grid;grid-template-columns:repeat(2,1fr);border-top:1px solid var(--ink);margin-bottom:90px}.chapter-index a{display:flex;gap:14px;padding:14px 8px;border-bottom:1px solid var(--line);font:.78rem/1.3 var(--sans)}.chapter-index span{font:600 .7rem var(--mono);color:var(--red)}.chapter{display:grid;grid-template-columns:100px minmax(0,800px);gap:30px;padding:80px 0;border-top:1px solid var(--ink);scroll-margin-top:30px}.chapter-number{font:clamp(3rem,7vw,7rem)/.8 var(--serif);color:#c8bfb1}.chapter-body h2{font:clamp(2.2rem,4vw,4.2rem)/.92 var(--serif);letter-spacing:-.055em;margin:0 0 22px}.chapter-body>p{font:1.05rem/1.65 var(--sans);max-width:720px}.chapter-body .chapter-intro{font:1.45rem/1.35 var(--serif);max-width:760px}.chapter-body ul{padding-left:1.2rem;line-height:1.6}.chapter-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin:34px 0}.chapter-metrics div{background:#f5efe5;padding:22px}.chapter-metrics strong{display:block;font:2rem/.95 var(--serif);color:var(--red)}.chapter-metrics span{font:.72rem/1.3 var(--mono)}.chapter-chart{margin:36px 0;padding:24px;background:#e9e1d4}.chapter-chart figcaption{display:flex;justify-content:space-between;margin-bottom:20px;font:.75rem var(--mono);text-transform:uppercase}.chapter-chart figcaption span{color:var(--muted)}.chapter-chart p{display:grid;grid-template-columns:130px 1fr 45px;gap:12px;align-items:center;margin:10px 0;font:.72rem var(--mono)}.chapter-chart i{height:13px;background:#d8cfc2}.chapter-chart i b{display:block;height:100%;background:var(--red)}.chapter-chart small,.chapter-source{font:.7rem/1.4 var(--mono);color:var(--muted)}.chapter-source{text-decoration:underline}@media(max-width:700px){.metrics,.chapter-metrics{grid-template-columns:1fr}.metrics div{border-bottom:1px solid var(--line)}.evidence{padding:55px 0}.investigation{padding-top:65px}.chapter-index{grid-template-columns:1fr}.chapter{grid-template-columns:1fr;padding:55px 0}.chapter-number{font-size:3rem}.chapter-chart{padding:16px}.chapter-chart p{grid-template-columns:90px 1fr 34px}}</style>
