---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { concerns, getConcern } from '../../data/concerns';
export function getStaticPaths() { return concerns.map((concern) => ({ params: { slug: concern.slug } })); }
const concern = getConcern(Astro.params.slug!);
if (!concern) return Astro.redirect('/');
---
<BaseLayout title={`${concern.title} — El país está fatal`} description={concern.summary}>
  <article class="brief"><a class="back" href="/#preocupaciones">← Volver a las 20 preocupaciones</a><header class="brief-head"><p class="eyebrow">Preocupación {String(concern.rank).padStart(2,'0')} de 20</p><h1>{concern.title}</h1><p>{concern.summary}</p></header>
  <section class="stat-block"><p class="eyebrow">Mención como problema principal</p><strong>{concern.stat}</strong><p>{concern.statLabel}</p><small>Fuente de prevalencia disponible en las fuentes de esta ficha.</small></section>
  <section class="brief-grid"><div><p class="eyebrow">La pregunta</p><h2>{concern.question}</h2><p>{concern.context}</p></div><aside><p class="eyebrow">Límite importante</p><p>{concern.limits}</p></aside></section>
  {concern.evidence && <section class="evidence"><p class="eyebrow">Datos en contexto</p><h2>{concern.evidence.heading}</h2><p>{concern.evidence.intro}</p><div class="metrics">{concern.evidence.metrics.map(metric => <div><strong>{metric.value}</strong><span>{metric.label}</span></div>)}</div><div class="chart"><div class="chart-title"><span>{concern.evidence.series.label}</span><small>{concern.evidence.series.unit}</small></div><div class="bars">{concern.evidence.series.values.map((value,index) => <div><i style={`height:${Math.min(100,Math.abs(value)/Math.max(...concern.evidence!.series.values.map(Math.abs))*100)}%`}></i><b>{value}</b><span>{concern.evidence!.series.labels[index]}</span></div>)}</div></div><a class="data-source" href={concern.evidence.source.url} target="_blank" rel="noreferrer">Datos: {concern.evidence.source.publisher} · {concern.evidence.source.date} ↗</a></section>}
  {concern.video && <section class="video-card" data-video-id={concern.video.videoId}><div><p class="eyebrow">Vídeo · selección provisional</p><h2>{concern.video.title}</h2><p>{concern.video.publisher}</p><p class="video-note">{concern.video.note} <a href={concern.video.url} target="_blank" rel="noreferrer">Ver en YouTube ↗</a></p><button type="button" class="video-load">Cargar vídeo externo <span>▶</span></button></div><div class="play" aria-hidden="true">▶</div></section>}
  <section class="source-section"><div><p class="eyebrow">Comprueba las fuentes</p><h2>De dónde sale<br /><em>esta ficha.</em></h2></div><ol>{concern.sources.map((source, index) => <li><span>{String(index + 1).padStart(2,'0')}</span><a href={source.url} target="_blank" rel="noreferrer"><strong>{source.label}</strong><small>{source.publisher} · {source.date}</small></a><i>↗</i></li>)}</ol></section>
  <nav class="brief-nav"><a href={`/preocupaciones/${concerns[Math.max(0, concern.rank - 2)].slug}`}>← Anterior</a><a href="/#preocupaciones">Ver las 20</a><a href={`/preocupaciones/${concerns[Math.min(concerns.length - 1, concern.rank)].slug}`}>Siguiente →</a></nav></article>
  <script>document.querySelectorAll<HTMLElement>('.video-card').forEach((card) => { card.querySelector('.video-load')?.addEventListener('click', () => { const id = card.dataset.videoId; if (!id) return; card.style.cssText = 'display:block;padding:0;aspect-ratio:16/9'; card.innerHTML = `<iframe title="Vídeo de YouTube" src="https://www.youtube-nocookie.com/embed/${id}?autoplay=1" loading="lazy" style="width:100%;height:100%;border:0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>`; }); });</script>
</BaseLayout>
<style>.concerns li a{grid-template-columns:85px 1fr auto 30px;gap:18px}.list-stat{font:clamp(1.1rem,2vw,1.7rem)/1 var(--serif);color:var(--red);white-space:nowrap}.stat-block{margin-top:0;padding:24px 30px;display:grid;grid-template-columns:auto 1fr;gap:5px 25px;align-items:baseline}.stat-block .eyebrow,.stat-block small{grid-column:1/-1}.stat-block strong{font-size:clamp(2rem,4vw,4rem)}.stat-block>p{font-size:1rem;margin:0;max-width:270px}.evidence{padding:80px 0;border-bottom:1px solid var(--line)}.evidence h2{font:clamp(2.4rem,4vw,4rem)/.9 var(--serif);letter-spacing:-.06em;margin:0 0 20px}.evidence>p{max-width:700px;font:1.25rem/1.35 var(--serif)}.metrics{display:grid;grid-template-columns:repeat(3,1fr);margin:42px 0 30px;border-top:1px solid var(--ink)}.metrics div{padding:18px;border-right:1px solid var(--line)}.metrics strong{display:block;font:clamp(1.8rem,3.5vw,3.4rem)/.9 var(--serif);letter-spacing:-.06em}.metrics span{font-size:.75rem;color:var(--muted)}.chart{background:#e9e1d4;padding:24px}.chart-title{display:flex;justify-content:space-between;font:600 .75rem var(--mono);text-transform:uppercase}.bars{height:180px;display:flex;align-items:end;gap:10px;margin-top:24px}.bars div{height:100%;flex:1;display:flex;flex-direction:column;justify-content:end;align-items:center;gap:5px}.bars i{display:block;width:100%;background:var(--red)}.bars b{font:.68rem var(--mono)}.bars span{font-size:.6rem;color:var(--muted)}.data-source{display:inline-block;margin-top:12px;font-size:.75rem;text-decoration:underline}@media(max-width:700px){.concerns li a{grid-template-columns:42px 1fr auto 18px;gap:7px}.list-stat{font-size:1rem}.stat-block{grid-template-columns:1fr;padding:24px}.stat-block strong{font-size:3rem}.metrics{grid-template-columns:1fr}.metrics div{border-bottom:1px solid var(--line)}.evidence{padding:55px 0}}</style>
