---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { concerns, getConcern } from '../../data/concerns';
import { Content as ViviendaContent, frontmatter as vivienda } from '../../../investigaciones/vivienda/index.md';
export function getStaticPaths() { return concerns.map((concern) => ({ params: { slug: concern.slug } })); }
const concern = getConcern(Astro.params.slug!);
if (!concern) return Astro.redirect('/');
---
<BaseLayout title={`${concern.title} — El país está fatal`} description={concern.summary}>
  <article class="brief"><a class="back" href="/#preocupaciones">← Volver a las 20 preocupaciones</a><header class="brief-head"><p class="eyebrow">Dossier {String(concern.rank).padStart(2,'0')} de 20</p><h1>{concern.title}</h1><p>{concern.summary}</p><p class="survey-badge"><b>{concern.stat}</b> {concern.statLabel} · <a href={concern.sources[0].url} target="_blank" rel="noreferrer">ver fuente ↗</a></p></header>
  <section class="brief-grid"><div><p class="eyebrow">La pregunta</p><h2>{concern.question}</h2><p>{concern.context}</p></div><aside><p class="eyebrow">Límite importante</p><p>{concern.limits}</p></aside></section>
  <section class="evidence"><p class="eyebrow">{concern.dossier.eyebrow}</p><h2>{concern.dossier.heading}</h2><p>{concern.dossier.intro}</p><div class="metrics">{concern.dossier.metrics.map(metric => <div><strong>{metric.value}</strong><span>{metric.label}</span></div>)}</div><div class="chart"><div class="chart-title"><span>{concern.dossier.series.label}</span><small>{concern.dossier.series.unit}</small></div><div class="bars">{concern.dossier.series.values.map((value,index) => <div><i style={`height:${Math.min(100,Math.abs(value)/Math.max(...concern.dossier.series.values.map(Math.abs))*100)}%`}></i><b>{value}</b><span>{concern.dossier.series.labels[index]}</span></div>)}</div></div><a class="data-source" href={concern.dossier.source.url} target="_blank" rel="noreferrer">Datos: {concern.dossier.source.publisher} · {concern.dossier.source.date} ↗</a><p class="evidence-limit">{concern.dossier.limits}</p></section>
  {concern.slug === 'vivienda' && <div class="investigation"><header class="investigation-head"><p class="eyebrow">{vivienda.kicker}</p><h2>{vivienda.title}</h2><p>{vivienda.standfirst}</p><blockquote>{vivienda.finding}</blockquote></header><nav class="chapter-index" aria-label="Índice de la investigación">{vivienda.chapters.map((chapter: { id:string; number:string; title:string }) => <a href={`#${chapter.id}`}><span>{chapter.number}</span>{chapter.title}</a>)}</nav><div class="markdown-investigation"><ViviendaContent /></div></div>}
  {concern.video && <section class="video-card" data-video-id={concern.video.videoId}><div><p class="eyebrow">Vídeo · selección provisional</p><h2>{concern.video.title}</h2><p>{concern.video.publisher}</p><p class="video-note">{concern.video.note} <a href={concern.video.url} target="_blank" rel="noreferrer">Ver en YouTube ↗</a></p><button type="button" class="video-load">Cargar vídeo externo <span>▶</span></button></div><div class="play" aria-hidden="true">▶</div></section>}
  <section class="source-section"><div><p class="eyebrow">Comprueba las fuentes</p><h2>De dónde sale<br /><em>esta ficha.</em></h2></div><ol>{concern.sources.map((source, index) => <li><span>{String(index + 1).padStart(2,'0')}</span><a href={source.url} target="_blank" rel="noreferrer"><strong>{source.label}</strong><small>{source.publisher} · {source.date}</small></a><i>↗</i></li>)}</ol></section>
  <nav class="brief-nav"><a href={`/preocupaciones/${concerns[Math.max(0, concern.rank - 2)].slug}`}>← Anterior</a><a href="/#preocupaciones">Ver las 20</a><a href={`/preocupaciones/${concerns[Math.min(concerns.length - 1, concern.rank)].slug}`}>Siguiente →</a></nav></article>
  <script>document.querySelectorAll<HTMLElement>('.video-card').forEach((card) => { card.querySelector('.video-load')?.addEventListener('click', () => { const id = card.dataset.videoId; if (!id) return; card.style.cssText = 'display:block;padding:0;aspect-ratio:16/9'; card.innerHTML = `<iframe title="Vídeo de YouTube" src="https://www.youtube-nocookie.com/embed/${id}?autoplay=1" loading="lazy" style="width:100%;height:100%;border:0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>`; }); });</script>
</BaseLayout>
<style>.survey-badge{display:inline-flex;gap:7px;align-items:center;margin:30px 0 0!important;padding:8px 10px;background:#e9e1d4;font:.68rem/1.2 var(--mono)!important;color:var(--muted)}.survey-badge b{color:var(--red)}.survey-badge a{text-decoration:underline}.evidence{padding:80px 0;border-bottom:1px solid var(--line)}.evidence h2,.investigation-head h2{font:clamp(2.4rem,5vw,5.6rem)/.88 var(--serif);letter-spacing:-.065em;margin:0 0 20px}.evidence>p{max-width:700px;font:1.25rem/1.35 var(--serif)}.metrics{display:grid;grid-template-columns:repeat(3,1fr);margin:42px 0 30px;border-top:1px solid var(--ink)}.metrics div{padding:18px;border-right:1px solid var(--line)}.metrics strong{display:block;font:clamp(1.8rem,3.5vw,3.4rem)/.9 var(--serif);letter-spacing:-.06em}.metrics span{font-size:.75rem;color:var(--muted)}.chart{background:#e9e1d4;padding:24px}.chart-title{display:flex;justify-content:space-between;font:600 .75rem var(--mono);text-transform:uppercase}.bars{height:180px;display:flex;align-items:end;gap:10px;margin-top:24px}.bars div{height:100%;flex:1;display:flex;flex-direction:column;justify-content:end;align-items:center;gap:5px}.bars i{display:block;width:100%;background:var(--red)}.bars b{font:.68rem var(--mono)}.bars span{font-size:.6rem;color:var(--muted)}.data-source{display:inline-block;margin-top:12px;font-size:.75rem;text-decoration:underline}.evidence-limit{font:italic .9rem/1.45 var(--sans)!important;color:var(--muted);margin-top:16px}.investigation{padding-top:100px}.investigation-head{max-width:920px;margin-bottom:65px}.investigation-head>p{font:clamp(1.2rem,2vw,1.65rem)/1.4 var(--serif);max-width:760px}.investigation blockquote,.chapter blockquote{margin:32px 0;padding:22px 26px;border-left:5px solid var(--red);background:#e9e1d4;font:1.25rem/1.35 var(--serif)}.chapter-index{display:grid;grid-template-columns:repeat(2,1fr);border-top:1px solid var(--ink);margin-bottom:90px}.chapter-index a{display:flex;gap:14px;padding:14px 8px;border-bottom:1px solid var(--line);font:.78rem/1.3 var(--sans)}.chapter-index span{font:600 .7rem var(--mono);color:var(--red)}.chapter{display:grid;grid-template-columns:100px minmax(0,800px);gap:30px;padding:80px 0;border-top:1px solid var(--ink);scroll-margin-top:30px}.chapter-number{font:clamp(3rem,7vw,7rem)/.8 var(--serif);color:#c8bfb1}.chapter-body h2{font:clamp(2.2rem,4vw,4.2rem)/.92 var(--serif);letter-spacing:-.055em;margin:0 0 22px}.chapter-body>p{font:1.05rem/1.65 var(--sans);max-width:720px}.chapter-body .chapter-intro{font:1.45rem/1.35 var(--serif);max-width:760px}.chapter-body ul{padding-left:1.2rem;line-height:1.6}.chapter-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin:34px 0}.chapter-metrics div{background:#f5efe5;padding:22px}.chapter-metrics strong{display:block;font:2rem/.95 var(--serif);color:var(--red)}.chapter-metrics span{font:.72rem/1.3 var(--mono)}.chapter-chart{margin:36px 0;padding:24px;background:#e9e1d4}.chapter-chart figcaption{display:flex;justify-content:space-between;margin-bottom:20px;font:.75rem var(--mono);text-transform:uppercase}.chapter-chart figcaption span{color:var(--muted)}.chapter-chart p{display:grid;grid-template-columns:130px 1fr 45px;gap:12px;align-items:center;margin:10px 0;font:.72rem var(--mono)}.chapter-chart i{height:13px;background:#d8cfc2}.chapter-chart i b{display:block;height:100%;background:var(--red)}.chapter-chart small,.chapter-source{font:.7rem/1.4 var(--mono);color:var(--muted)}.chapter-source{text-decoration:underline}@media(max-width:700px){.metrics,.chapter-metrics{grid-template-columns:1fr}.metrics div{border-bottom:1px solid var(--line)}.evidence{padding:55px 0}.investigation{padding-top:65px}.chapter-index{grid-template-columns:1fr}.chapter{grid-template-columns:1fr;padding:55px 0}.chapter-number{font-size:3rem}.chapter-chart{padding:16px}.chapter-chart p{grid-template-columns:90px 1fr 34px}}</style>
<style>
  .markdown-investigation { max-width: 820px; margin-left: 130px; }
  .markdown-investigation :global(h2) { scroll-margin-top: 30px; margin: 0; padding: 76px 0 22px; border-top: 1px solid var(--ink); font: clamp(2.2rem,4vw,4.2rem)/.92 var(--serif); letter-spacing: -.055em; }
  .markdown-investigation :global(h2:first-of-type) { border-top: 0; }
  .markdown-investigation :global(p), .markdown-investigation :global(li) { font: 1.05rem/1.65 var(--sans); }
  .markdown-investigation :global(blockquote) { margin: 0 0 45px; padding: 18px 22px; border-left: 4px solid var(--red); background: #e9e1d4; }
  .markdown-investigation :global(blockquote p) { margin: 0; font: italic .9rem/1.5 var(--sans); color: var(--muted); }
  .markdown-investigation :global(a) { text-decoration: underline; text-underline-offset: 3px; }
  .markdown-investigation :global(h2 + p) { font: 1.4rem/1.4 var(--serif); }
  .markdown-investigation :global(h2#fuentes-principales) { margin-top: 70px; }
  @media(max-width: 700px) { .markdown-investigation { margin-left: 0; } .markdown-investigation :global(h2) { padding-top: 55px; } }
</style>
