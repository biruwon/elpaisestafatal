---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { claims,getClaim,assessmentLabels } from '../../data/claims';
export function getStaticPaths(){return claims.map(item=>({params:{slug:item.slug}}));}
const item=getClaim(Astro.params.slug!); if(!item)return Astro.redirect('/verificaciones');
---
<BaseLayout title={`${item.claim} — Verificación`} description={item.shareable}><article class="claim-page"><a class="back" href="/verificaciones">← Ver las 20 verificaciones</a><header><p class="eyebrow">Verificación · {item.topic}</p><h1>{item.claim}</h1><strong class={`assessment assessment-${item.assessment}`}>{assessmentLabels[item.assessment]}</strong></header><section class="claim-grid"><article><p class="eyebrow">Qué es cierto</p><p>{item.whatIsTrue}</p></article><article><p class="eyebrow">Qué falta</p><p>{item.whatIsMissing}</p></article><article><p class="eyebrow">Escala relevante</p><p>{item.scale}</p></article><article><p class="eyebrow">Qué no pueden probar los datos</p><p>{item.cannotProve}</p></article></section><blockquote>{item.shareable}</blockquote><p class="topic-link"><a href={`/preocupaciones/${item.topicSlug}`}>Leer la investigación completa sobre {item.topic} →</a></p><section class="claim-sources"><p class="eyebrow">Fuentes originales</p>{item.sources.map((source,index)=><a href={source.url} target="_blank" rel="noreferrer"><span>{String(index+1).padStart(2,'0')}</span><strong>{source.label}</strong><small>{source.publisher} · {source.date} ↗</small></a>)}</section></article></BaseLayout>
<style>.claim-page{max-width:1000px;margin:auto;padding:45px 30px 100px}.claim-page header{padding:100px 0 60px;border-bottom:1px solid var(--ink)}.claim-page h1{font:clamp(3.2rem,7vw,7rem)/.86 var(--serif);letter-spacing:-.07em;margin:0 0 35px}.assessment{display:inline-block;padding:9px 13px;background:var(--yellow);font:.7rem var(--mono);text-transform:uppercase}.assessment-false{background:#f1b4aa}.assessment-true,.assessment-mostly-true{background:#cfe5cb}.claim-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line);margin:50px 0}.claim-grid article{background:var(--paper);padding:28px;min-height:190px}.claim-grid p:last-child{font:1.3rem/1.3 var(--serif)}.claim-page blockquote{font:1.6rem/1.3 var(--serif);margin:45px 0;padding:30px;border-left:6px solid var(--red);background:#e9e1d4}.topic-link{font-weight:700}.claim-sources{margin-top:80px;border-top:1px solid var(--ink);padding-top:25px}.claim-sources>a{display:grid;grid-template-columns:45px 1fr auto;gap:15px;padding:15px 0;border-bottom:1px solid var(--line)}.claim-sources span{font:.65rem var(--mono);color:var(--red)}.claim-sources small{color:var(--muted)}@media(max-width:700px){.claim-grid{grid-template-columns:1fr}.claim-page{padding:30px 20px 70px}.claim-page header{padding-top:70px}.claim-sources>a{grid-template-columns:30px 1fr}.claim-sources small{grid-column:2}}</style>
